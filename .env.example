# Copie ce fichier en .env et remplis les valeurs.
# NE COMMITE JAMAIS le .env (il contient ta clé secrète Brevo).

# Clé API Brevo : Brevo > Paramètres > SMTP & API > Clés API (v3)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la liste Brevo cible : Brevo > Contacts > Listes (colonne ID)
BREVO_LIST_ID=1

# Lien d'invitation du groupe WhatsApp (WhatsApp > Infos du groupe > Inviter via un lien)
WHATSAPP_INVITE_URL=https://chat.whatsapp.com/XXXXXXXXXXXXXXXXX

# Expéditeur des newsletters (doit être un expéditeur vérifié dans Brevo)
BREVO_SENDER_EMAIL=didgeridoo@mirko.re
BREVO_SENDER_NAME=Didgeridoo Belgique

# SMTP Pocketbase (e-mails de vérification de compte + mot de passe oublié).
# Brevo > Paramètres > SMTP & API > onglet SMTP : login + clé SMTP (différente de la clé API).
# Sans SMTP_PASSWORD, l'envoi d'e-mails Pocketbase reste désactivé.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=ton-login@smtp-brevo.com
SMTP_PASSWORD=
SMTP_SENDER=didgeridoo@mirko.re

# URL publique du site (liens dans les e-mails Pocketbase)
APP_URL=https://didgeridoo.top
