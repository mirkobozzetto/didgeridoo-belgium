---
// Pilule compte + dropdown : tout ce qui concerne le compte connecté.
import { menuItem as menuItemStyle } from '../lib/menu-styles'

const menuItem = menuItemStyle()
---

<button
  type="button"
  data-menu-trigger
  aria-haspopup="true"
  aria-expanded="false"
  class="flex shrink-0 items-center gap-2 rounded-full py-1 pl-1 pr-2 ring-1 ring-stone-900/10 transition-colors hover:bg-white"
>
  <span
    data-initial
    class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-100 text-[12px] font-bold text-brand-700 ring-1 ring-inset ring-brand-200"
  ></span>
  <span
    data-account-name
    class="hidden max-w-[140px] truncate text-[13px] font-medium text-stone-700 @min-[30rem]:block"
  ></span>
  <span
    data-admin-badge
    hidden
    class="rounded-full bg-brand-100 px-2 py-0.5 text-[9.5px] font-semibold uppercase tracking-[0.14em] text-brand-700 ring-1 ring-inset ring-brand-200"
    >Admin</span
  >
  <svg
    class="h-3.5 w-3.5 text-stone-400"
    viewBox="0 0 20 20"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      fill-rule="evenodd"
      d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z"
      clip-rule="evenodd"></path>
  </svg>
</button>

<div
  data-menu
  hidden
  class="absolute right-0 top-full z-20 mt-2 w-60 max-w-[calc(100vw-16px)] overflow-hidden rounded-xl bg-white py-1.5 shadow-pop ring-1 ring-stone-900/5"
>
  <a href="/calendrier" data-menu-key="calendrier" class={menuItem}
    >Calendrier</a
  >
  <a href="/annonces" data-menu-key="annonces" class={menuItem}>Annonces</a>
  <a href="/mes-propositions" data-menu-key="mes-propositions" class={menuItem}
    >Mes propositions</a
  >
  <div data-admin-only hidden>
    <p
      class="px-4 pb-1 pt-2.5 text-[9.5px] font-semibold uppercase tracking-[0.18em] text-stone-400"
    >
      Administration
    </p>
    <a href="/admin" data-menu-key="admin" class={menuItem}>Modération</a>
    <a href="/admin/newsletter" data-menu-key="newsletter" class={menuItem}
      >Newsletter</a
    >
  </div>
  <div class="my-1.5 border-t border-stone-900/10"></div>
  <button type="button" data-logout class={menuItem}>Déconnexion</button>
</div>

<script>
  import { clearAllAuth } from '../lib/pb'
  import { initMenuToggle } from '../lib/menu-toggle'

  // Astro bundle ce script même quand PageShell ne rend pas la nav :
  // sans garde, le crash bloque tous les autres scripts de la page.
  const root = document.querySelector<HTMLElement>('[data-account-nav]')
  if (root) {
    // Tous les popovers du header : menu compte + burger mobile.
    for (const trigger of root.querySelectorAll<HTMLElement>(
      '[data-menu-trigger]',
    )) {
      const menu =
        trigger.parentElement?.querySelector<HTMLElement>('[data-menu]')
      if (menu) initMenuToggle(trigger, menu)
    }

    const activeKey = root.dataset.active
    const current = root.querySelector<HTMLElement>(
      `[data-menu-key="${activeKey}"]`,
    )
    if (current) {
      current.classList.remove('text-stone-600')
      current.classList.add('text-stone-900', 'font-semibold')
      current.setAttribute('aria-current', 'page')
    }

    const logout = root.querySelector<HTMLButtonElement>('[data-logout]')
    if (logout) {
      logout.addEventListener('click', () => {
        clearAllAuth()
        location.href = '/'
      })
    }
  }
</script>
