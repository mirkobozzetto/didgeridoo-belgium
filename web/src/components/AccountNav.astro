---
import Brand from './Brand.astro'
import AccountMenu from './AccountMenu.astro'
import { AUTH_KEY, ADMIN_AUTH_KEY } from '../lib/pb'
import { btn } from '../lib/button-styles'

interface Props {
  active?:
    'calendrier' | 'proposer' | 'mes-propositions' | 'admin' | 'newsletter'
}
const { active } = Astro.props
---

<header
  data-account-nav
  data-active={active}
  data-auth-key={AUTH_KEY}
  data-admin-auth-key={ADMIN_AUTH_KEY}
  class="@container relative flex items-center justify-between gap-3 border-b border-stone-900/10 pb-4"
>
  <div class="flex min-w-0 items-center gap-5">
    <Brand />
    <a
      href="/calendrier"
      class="hidden whitespace-nowrap text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400 transition-colors hover:text-stone-600 @min-[42rem]:block"
      >Calendrier</a
    >
    <a
      href="/annonces"
      class="hidden whitespace-nowrap text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400 transition-colors hover:text-stone-600 @min-[42rem]:block"
      >Annonces</a
    >
  </div>

  <nav data-signed-out hidden class="flex shrink-0 items-center gap-3">
    <a
      href="/connexion"
      class:list={[btn('outline', 'xs'), 'whitespace-nowrap']}>Se connecter</a
    >
  </nav>

  <nav data-signed-in hidden class="flex shrink-0 items-center gap-3">
    {
      active !== 'proposer' && (
        <a
          href="/proposer"
          class:list={[btn('primary', 'xs'), 'whitespace-nowrap']}
        >
          <span class="@min-[36rem]:hidden">Proposer</span>
          <span class="hidden @min-[36rem]:inline">Proposer un événement</span>
        </a>
      )
    }
    <AccountMenu />
  </nav>
</header>

<!-- Synchrone exprès : révèle l'état connecté AVANT le premier paint,
     sinon le header "pop" à chaque navigation. -->
<script is:inline>
  ;(() => {
    const root = document.querySelector('[data-account-nav]')
    if (!root) return
    const read = (key) => {
      try {
        const parsed = JSON.parse(localStorage.getItem(key) || 'null')
        return parsed && parsed.token ? parsed : null
      } catch {
        return null
      }
    }
    const organizer = read(root.dataset.authKey)
    const admin = read(root.dataset.adminAuthKey)
    const connected = organizer || admin
    if (!connected) {
      root.querySelector('[data-signed-out]').hidden = false
      return
    }
    root.querySelector('[data-signed-in]').hidden = false
    const who = connected.record.name || connected.record.email
    root.querySelector('[data-account-name]').textContent = who
    root.querySelector('[data-initial]').textContent = who
      .charAt(0)
      .toUpperCase()
    if (admin) {
      root.querySelector('[data-admin-badge]').hidden = false
      root.querySelector('[data-admin-only]').hidden = false
    }
  })()
</script>
