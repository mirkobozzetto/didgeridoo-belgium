---
import Brand from './Brand.astro'
import AccountMenu from './AccountMenu.astro'
import { AUTH_KEY, ADMIN_AUTH_KEY } from '../lib/pb'

interface Props {
  active?:
    'calendrier' | 'proposer' | 'mes-propositions' | 'admin' | 'newsletter'
}
const { active } = Astro.props
---

<header
  data-account-nav
  data-active={active}
  data-auth-key={AUTH_KEY}
  data-admin-auth-key={ADMIN_AUTH_KEY}
  class="relative flex items-center justify-between gap-3 border-b border-stone-900/10 pb-4"
>
  <div class="flex min-w-0 items-center gap-5">
    <Brand />
    <a
      href="/calendrier"
      class="hidden whitespace-nowrap text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400 transition-colors hover:text-stone-600 lg:block"
      >Calendrier</a
    >
  </div>

  <nav data-signed-out hidden class="flex shrink-0 items-center gap-3">
    <a
      href="/connexion"
      class="whitespace-nowrap rounded-full border border-stone-900/15 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-stone-600 transition-colors hover:border-brand-600 hover:text-brand-600"
      >Se connecter</a
    >
  </nav>

  <nav data-signed-in hidden class="flex shrink-0 items-center gap-3">
    {
      active !== 'proposer' && (
        <a
          href="/proposer"
          class="inline-flex items-center whitespace-nowrap rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 px-3.5 py-2 text-[13px] font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px"
        >
          <span class="lg:hidden">Proposer</span>
          <span class="hidden lg:inline">Proposer un événement</span>
        </a>
      )
    }
    <AccountMenu />
  </nav>
</header>

<!-- Synchrone exprès : révèle l'état connecté AVANT le premier paint,
     sinon le header "pop" à chaque navigation. -->
<script is:inline>
  ;(() => {
    const root = document.querySelector('[data-account-nav]')
    if (!root) return
    const read = (key) => {
      try {
        const parsed = JSON.parse(localStorage.getItem(key) || 'null')
        return parsed && parsed.token ? parsed : null
      } catch {
        return null
      }
    }
    const organizer = read(root.dataset.authKey)
    const admin = read(root.dataset.adminAuthKey)
    const connected = organizer || admin
    if (!connected) {
      root.querySelector('[data-signed-out]').hidden = false
      return
    }
    root.querySelector('[data-signed-in]').hidden = false
    const who = connected.record.name || connected.record.email
    root.querySelector('[data-account-name]').textContent = who
    root.querySelector('[data-initial]').textContent = who
      .charAt(0)
      .toUpperCase()
    if (admin) {
      root.querySelector('[data-admin-badge]').hidden = false
      root.querySelector('[data-admin-only]').hidden = false
    }
  })()
</script>
