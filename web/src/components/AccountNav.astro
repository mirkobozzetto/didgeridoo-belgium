---
interface Props {
  active?: 'proposer' | 'mes-propositions' | 'admin' | 'newsletter'
}
const { active } = Astro.props

const menuItem =
  'block w-full px-4 py-2 text-left text-[13px] text-stone-600 transition-colors hover:bg-stone-50 hover:text-stone-900'
---

<header
  data-account-nav
  data-active={active}
  class="relative flex items-center justify-between gap-3 border-b border-stone-900/10 pb-4"
>
  <div class="flex min-w-0 items-center gap-5">
    <a href="/" class="shrink-0 text-[13.5px] font-extrabold tracking-[0.08em]">
      <span class="text-stone-900">didge</span><span class="text-flag-yellow"
        >ridoo</span
      ><span class="text-flag-red">.top</span>
    </a>
    <a
      href="/calendrier"
      class="hidden text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400 transition-colors hover:text-stone-600 sm:block"
      >Calendrier</a
    >
  </div>

  <nav data-signed-out hidden class="flex items-center gap-3">
    <a
      href="/connexion"
      class="rounded-full border border-stone-900/15 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-stone-600 transition-colors hover:border-brand-600 hover:text-brand-600"
      >Se connecter</a
    >
  </nav>

  <nav data-signed-in hidden class="flex items-center gap-3">
    {
      active !== 'proposer' && (
        <a
          href="/proposer"
          class="inline-flex items-center rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 px-3.5 py-2 text-[13px] font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px"
        >
          Proposer un événement
        </a>
      )
    }

    <button
      type="button"
      data-menu-trigger
      aria-haspopup="true"
      aria-expanded="false"
      class="flex items-center gap-2 rounded-full py-1 pl-1 pr-2 ring-1 ring-stone-900/10 transition-colors hover:bg-white"
    >
      <span
        data-initial
        class="flex h-7 w-7 items-center justify-center rounded-full bg-brand-100 text-[12px] font-bold text-brand-700 ring-1 ring-inset ring-brand-200"
      ></span>
      <span
        data-account-name
        class="hidden max-w-[140px] truncate text-[13px] font-medium text-stone-700 sm:block"
      ></span>
      <span
        data-admin-badge
        hidden
        class="rounded-full bg-brand-100 px-2 py-0.5 text-[9.5px] font-semibold uppercase tracking-[0.14em] text-brand-700 ring-1 ring-inset ring-brand-200"
        >Admin</span
      >
      <svg
        class="h-3.5 w-3.5 text-stone-400"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.06l3.71-3.83a.75.75 0 1 1 1.08 1.04l-4.25 4.39a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06Z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <div
      data-menu
      hidden
      class="absolute right-0 top-full z-20 mt-2 w-56 overflow-hidden rounded-xl bg-white py-1.5 shadow-[0_2px_4px_rgb(0_0_0/0.04),0_24px_60px_-24px_rgb(28_25_23/0.4)] ring-1 ring-stone-900/5"
    >
      <a
        href="/mes-propositions"
        data-menu-key="mes-propositions"
        class={menuItem}>Mes propositions</a
      >
      <div data-admin-only hidden>
        <p
          class="px-4 pb-1 pt-2.5 text-[9.5px] font-semibold uppercase tracking-[0.18em] text-stone-400"
        >
          Administration
        </p>
        <a href="/admin" data-menu-key="admin" class={menuItem}>Modération</a>
        <a href="/admin/newsletter" data-menu-key="newsletter" class={menuItem}
          >Newsletter</a
        >
      </div>
      <div class="my-1.5 border-t border-stone-900/10"></div>
      <button type="button" data-logout class={menuItem}>Déconnexion</button>
    </div>
  </nav>
</header>

<script>
  import { getAuth, getAdminAuth, isAdmin, clearAllAuth } from '../lib/pb'

  const root = document.querySelector('[data-account-nav]') as HTMLElement
  const signedOut = root.querySelector('[data-signed-out]') as HTMLElement
  const signedIn = root.querySelector('[data-signed-in]') as HTMLElement

  const organizer = getAuth()
  const admin = getAdminAuth()
  const connected = organizer ?? admin

  if (!connected) {
    signedOut.hidden = false
  } else {
    signedIn.hidden = false
    const who = connected.record.name || connected.record.email
    ;(root.querySelector('[data-account-name]') as HTMLElement).textContent =
      who
    ;(root.querySelector('[data-initial]') as HTMLElement).textContent = who
      .charAt(0)
      .toUpperCase()

    if (isAdmin()) {
      ;(root.querySelector('[data-admin-badge]') as HTMLElement).hidden = false
      ;(root.querySelector('[data-admin-only]') as HTMLElement).hidden = false
    }

    const trigger = root.querySelector(
      '[data-menu-trigger]',
    ) as HTMLButtonElement
    const menu = root.querySelector('[data-menu]') as HTMLElement

    const activeKey = root.dataset.active
    const current = menu.querySelector<HTMLElement>(
      `[data-menu-key="${activeKey}"]`,
    )
    if (current) {
      current.classList.remove('text-stone-600')
      current.classList.add('text-stone-900', 'font-semibold')
      current.setAttribute('aria-current', 'page')
    }

    const close = () => {
      menu.hidden = true
      trigger.setAttribute('aria-expanded', 'false')
    }
    trigger.addEventListener('click', (e) => {
      e.stopPropagation()
      menu.hidden = !menu.hidden
      trigger.setAttribute('aria-expanded', String(!menu.hidden))
    })
    document.addEventListener('click', (e) => {
      if (!menu.hidden && !menu.contains(e.target as Node)) close()
    })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close()
    })

    ;(
      root.querySelector('[data-logout]') as HTMLButtonElement
    ).addEventListener('click', () => {
      clearAllAuth()
      location.href = '/'
    })
  }
</script>
