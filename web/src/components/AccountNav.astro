---
import Brand from './Brand.astro'
import AccountMenu from './AccountMenu.astro'
import AuthNavSync from './AuthNavSync.astro'
import { AUTH_KEY, ADMIN_AUTH_KEY } from '../lib/pb'
import { btn } from '../lib/button-styles'

interface Props {
  active?:
    | 'calendrier'
    | 'annonces'
    | 'proposer'
    | 'mes-propositions'
    | 'admin'
    | 'newsletter'
}
const { active } = Astro.props

const navLink =
  'whitespace-nowrap text-[13px] font-semibold text-stone-500 transition-colors hover:text-stone-900 aria-[current=page]:text-stone-900'
---

<header
  data-account-nav
  data-active={active}
  data-auth-key={AUTH_KEY}
  data-admin-auth-key={ADMIN_AUTH_KEY}
  class="@container relative flex items-center justify-between gap-3 border-b border-stone-900/10 pb-4"
>
  <div class="flex min-w-0 items-center gap-5">
    <Brand />
    <nav
      data-nav-links
      class="relative hidden items-center gap-6 @min-[42rem]:flex"
    >
      <a
        href="/calendrier"
        aria-current={active === 'calendrier' ? 'page' : undefined}
        class={navLink}>Calendrier</a
      >
      <a
        href="/annonces"
        aria-current={active === 'annonces' ? 'page' : undefined}
        class={navLink}>Annonces</a
      >
      <span
        data-nav-slider
        class="absolute -bottom-[17px] h-[2.5px] rounded-full bg-brand-600 opacity-0 transition-[left,width] duration-[280ms] ease-[cubic-bezier(.4,0,.2,1)]"
        aria-hidden="true"></span>
    </nav>
  </div>

  <nav data-signed-out hidden class="flex shrink-0 items-center gap-3">
    <a
      href="/connexion"
      class:list={[btn('outline', 'xs'), 'whitespace-nowrap']}>Se connecter</a
    >
  </nav>

  <nav data-signed-in hidden class="flex shrink-0 items-center gap-3">
    {
      active !== 'proposer' && (
        <a
          href="/proposer"
          class:list={[btn('primary', 'xs'), 'whitespace-nowrap']}
        >
          <span class="@min-[36rem]:hidden">Proposer</span>
          <span class="hidden @min-[36rem]:inline">Proposer un événement</span>
        </a>
      )
    }
    <AccountMenu />
  </nav>
</header>

<script>
  import { initNavSlider } from '../lib/nav-slider'
  document
    .querySelectorAll<HTMLElement>('[data-nav-links]')
    .forEach(initNavSlider)
</script>

<AuthNavSync />
