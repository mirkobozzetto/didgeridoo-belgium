---
// Lockup de marque : nom en bandes de couleurs nettes qui défilent
// (noir, or, rouge - jamais de fondu) au-dessus d'un didgeridoo SVG aux
// proportions réelles (tube quasi droit, ouverture creuse, cire en anneau,
// points clippés). Vibration et ondes sonores permanentes, amplifiées au
// survol. Tout est en place : aucun décalage de layout au hover.
interface Props {
  class?: string
}
const { class: className = 'text-[20px]' } = Astro.props
---

<a
  href="/"
  class={`didge-lockup shrink-0 ${className}`}
  aria-label="didgeridoo.top - accueil"
>
  <span class="lockup-text"
    ><span class="c-b">didge</span><span class="c-y">ridoo</span><span
      class="c-r">.top</span
    ></span
  >
  <svg
    class="lockup-graphic"
    viewBox="0 0 232 26"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="didge-wood" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#44403c"></stop>
        <stop offset="28%" stop-color="#c2410c"></stop>
        <stop offset="55%" stop-color="#ea580c"></stop>
        <stop offset="82%" stop-color="#c2410c"></stop>
        <stop offset="100%" stop-color="#44403c"></stop>
      </linearGradient>
      <linearGradient id="didge-cyl" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#ffffff" stop-opacity="0.22"></stop>
        <stop offset="45%" stop-color="#ffffff" stop-opacity="0"></stop>
        <stop offset="100%" stop-color="#1c1917" stop-opacity="0.30"></stop>
      </linearGradient>
      <clipPath id="didge-clip">
        <path
          d="M 4,9.8 C 14,9.3 22,8.9 30,8.8 C 45,8.7 58,9.1 70,9.2 C 85,9.2 98,8.2 110,7.8 C 122,7.5 134,7.4 145,7.2 C 156,7.0 166,6.4 175,5.5 C 183,4.7 190,4.1 196,3.5 L 196,22.5 C 190,21.9 183,21.2 175,20.5 C 166,19.8 156,19.5 145,19.2 C 134,18.9 122,18.1 110,17.8 C 98,17.6 85,17.7 70,17.6 C 58,17.5 45,16.4 30,16.0 C 22,15.9 14,16.1 4,16.2 Z"
        ></path>
      </clipPath>
    </defs>

    <g class="tube">
      <path
        d="M 4,9.8 C 14,9.3 22,8.9 30,8.8 C 45,8.7 58,9.1 70,9.2 C 85,9.2 98,8.2 110,7.8 C 122,7.5 134,7.4 145,7.2 C 156,7.0 166,6.4 175,5.5 C 183,4.7 190,4.1 196,3.5 L 196,22.5 C 190,21.9 183,21.2 175,20.5 C 166,19.8 156,19.5 145,19.2 C 134,18.9 122,18.1 110,17.8 C 98,17.6 85,17.7 70,17.6 C 58,17.5 45,16.4 30,16.0 C 22,15.9 14,16.1 4,16.2 Z"
        fill="url(#didge-wood)"></path>
      <path
        d="M 4,9.8 C 14,9.3 22,8.9 30,8.8 C 45,8.7 58,9.1 70,9.2 C 85,9.2 98,8.2 110,7.8 C 122,7.5 134,7.4 145,7.2 C 156,7.0 166,6.4 175,5.5 C 183,4.7 190,4.1 196,3.5 L 196,22.5 C 190,21.9 183,21.2 175,20.5 C 166,19.8 156,19.5 145,19.2 C 134,18.9 122,18.1 110,17.8 C 98,17.6 85,17.7 70,17.6 C 58,17.5 45,16.4 30,16.0 C 22,15.9 14,16.1 4,16.2 Z"
        fill="url(#didge-cyl)"></path>

      <g clip-path="url(#didge-clip)">
        <path
          d="M 6,11.6 C 50,11.2 110,10.4 194,8.2"
          stroke="#1c1917"
          stroke-width="0.55"
          fill="none"
          opacity="0.20"></path>
        <path
          d="M 6,14.4 C 60,14.6 120,14.8 194,17.6"
          stroke="#1c1917"
          stroke-width="0.45"
          fill="none"
          opacity="0.16"></path>
        <path
          d="M 10,12.8 C 60,12.6 110,12.5 160,12.6"
          stroke="#fff7ed"
          stroke-width="0.4"
          fill="none"
          opacity="0.18"></path>

        <g stroke-linecap="round" fill="none">
          <path
            d="M 54,9.6 C 56.4,12 56.4,15 54,17.2"
            stroke="#fff7ed"
            stroke-width="1.05"
            stroke-dasharray="0 2.4"></path>
          <path
            d="M 58,9.6 C 60.4,12 60.4,15 58,17.3"
            stroke="#ef3340"
            stroke-width="1.05"
            stroke-dasharray="0 2.4"></path>
          <path
            d="M 112,8.4 C 114.6,11.4 114.6,14.8 112,17.4"
            stroke="#fff7ed"
            stroke-width="1.05"
            stroke-dasharray="0 2.4"></path>
          <path
            d="M 116,8.4 C 118.6,11.4 118.6,14.8 116,17.5"
            stroke="#c9a10a"
            stroke-width="1.05"
            stroke-dasharray="0 2.4"></path>
          <path
            d="M 158,7.2 C 161,10.6 161,15.6 158,19.4"
            stroke="#fff7ed"
            stroke-width="1.1"
            stroke-dasharray="0 2.6"></path>
          <path
            d="M 162,7.0 C 165,10.6 165,15.8 162,19.7"
            stroke="#ef3340"
            stroke-width="1.1"
            stroke-dasharray="0 2.6"></path>
          <path
            d="M 166,6.8 C 169,10.6 169,16.0 166,20.0"
            stroke="#1c1917"
            stroke-width="1.1"
            stroke-dasharray="0 2.6"></path>
        </g>

        <path
          class="breath"
          d="M 6,13 C 60,12.6 120,12.8 194,13"
          stroke="#fff7ed"
          stroke-width="1"
          fill="none"
          stroke-linecap="round"></path>
      </g>

      <ellipse cx="196" cy="13" rx="3.4" ry="9.5" fill="#1c1917"></ellipse>
      <ellipse
        cx="196.6"
        cy="13"
        rx="2.2"
        ry="7.6"
        fill="#44403c"
        opacity="0.55"></ellipse>
      <path
        d="M 197.6,5.2 A 9,9 0 0 1 197.6,20.8"
        stroke="#fed7aa"
        stroke-width="0.7"
        fill="none"
        opacity="0.7"></path>

      <ellipse cx="4" cy="13" rx="1.5" ry="3.2" fill="#1c1917" opacity="0.85"
      ></ellipse>
      <ellipse
        cx="4"
        cy="13"
        rx="1.5"
        ry="3.2"
        fill="none"
        stroke="#c2410c"
        stroke-width="0.8"></ellipse>
    </g>

    <g fill="none" stroke-linecap="round" stroke-width="1.4">
      <path class="ripple r1" d="M 205,8 Q 210,13 205,18" stroke="#c9a10a"
      ></path>
      <path class="ripple r2" d="M 209,4.5 Q 216,13 209,21.5" stroke="#ef3340"
      ></path>
      <path class="ripple r3" d="M 213,1 Q 222,13 213,25" stroke="#ea580c"
      ></path>
      <path class="ripple r4" d="M 218,-2.5 Q 229,13 218,28.5" stroke="#f97316"
      ></path>
    </g>
  </svg>
</a>

<style>
  .didge-lockup {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.18em;
    line-height: 1;
    width: 9.2em;
  }

  /* Tricolore belge statique : noir, or, rouge. */
  .lockup-text {
    font-weight: 900;
    font-size: 1em;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .lockup-text .c-b {
    color: #1c1917;
  }
  .lockup-text .c-y {
    color: #c9a10a;
  }
  .lockup-text .c-r {
    color: #ef3340;
  }

  .lockup-graphic {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .tube {
    will-change: transform;
  }
  .didge-lockup:hover .tube {
    animation: vibe 0.9s ease-in-out infinite;
  }
  @keyframes vibe {
    0%,
    100% {
      transform: translateY(0);
    }
    25% {
      transform: translateY(-0.35px);
    }
    75% {
      transform: translateY(0.35px);
    }
  }

  .ripple {
    transform-origin: 198px 13px;
    opacity: 0;
  }
  .didge-lockup:hover .ripple {
    animation: pulse 1.1s ease-out infinite;
  }
  .didge-lockup:hover .ripple.r2 {
    animation-delay: 0.25s;
  }
  .didge-lockup:hover .ripple.r3 {
    animation-delay: 0.5s;
  }
  .didge-lockup:hover .ripple.r4 {
    animation-delay: 0.75s;
  }
  @keyframes pulse {
    0% {
      opacity: 0;
      transform: scale(0.85) translateX(-1.5px);
    }
    25% {
      opacity: 0.85;
    }
    100% {
      opacity: 0;
      transform: scale(1.12) translateX(4px);
    }
  }

  .breath {
    stroke-dasharray: 18 220;
    stroke-dashoffset: 238;
    opacity: 0;
  }
  .didge-lockup:hover .breath {
    animation: blow 1.4s linear infinite;
  }
  @keyframes blow {
    0% {
      stroke-dashoffset: 238;
      opacity: 0;
    }
    12% {
      opacity: 0.7;
    }
    88% {
      opacity: 0.7;
    }
    100% {
      stroke-dashoffset: -20;
      opacity: 0;
    }
  }
</style>
