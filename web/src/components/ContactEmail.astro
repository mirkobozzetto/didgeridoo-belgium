---
// Anti-spam : l'adresse n'existe ni dans le HTML servi, ni dans le DOM
// avant un clic humain. Segments inversés assemblés au clic uniquement ;
// aucun motif email dans le bundle.
---

<button
  type="button"
  class="font-semibold text-brand-600 hover:text-brand-700"
  data-contact>Afficher l'adresse e-mail</button
>

<script>
  const assemble = () =>
    ['er.okrim', 'oodiregdid']
      .map((s) => [...s].reverse().join(''))
      .reverse()
      .join(String.fromCharCode(64))

  document
    .querySelectorAll<HTMLButtonElement>('button[data-contact]')
    .forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          const addr = assemble()
          const link = document.createElement('a')
          link.href = `mailto:${addr}`
          link.textContent = addr
          link.className = btn.className
          btn.replaceWith(link)
        },
        { once: true },
      )
    })
</script>
