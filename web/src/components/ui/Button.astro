---
import { btn, type BtnVariant, type BtnSize } from '../../lib/button-styles'

interface Props {
  variant?: BtnVariant
  size?: BtnSize
  type?: 'button' | 'submit'
  id?: string
  disabled?: boolean
  class?: string
}
const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  id,
  disabled = false,
  class: className,
} = Astro.props
---

<button {id} {type} {disabled} class:list={[btn(variant, size), className]}>
  <slot />
</button>
