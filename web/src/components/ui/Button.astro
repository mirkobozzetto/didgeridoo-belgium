---
interface Props {
  variant?: 'primary' | 'dark'
  size?: 'xs' | 'sm' | 'md' | 'lg'
  type?: 'button' | 'submit'
  id?: string
  disabled?: boolean
  class?: string
}
const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  id,
  disabled = false,
  class: className,
} = Astro.props

const variants = {
  primary:
    'inline-flex items-center justify-center rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px',
  dark: 'inline-flex items-center justify-center rounded-xl bg-stone-900 font-semibold text-white transition hover:bg-stone-700 active:translate-y-px',
}
const sizes = {
  xs: 'px-3.5 py-2 text-[13px]',
  sm: 'px-4 py-2.5 text-[14px]',
  md: 'px-5 py-2.5 text-[14px]',
  lg: 'px-5 py-3.5 text-[15px]',
}
---

<button
  {id}
  {type}
  {disabled}
  class:list={[variants[variant], sizes[size], className]}
>
  <slot />
</button>
