---
import { pillSegment } from '../../lib/pill-styles'

// Segment d'un PillGroup : <a> si href, <button type="button"> sinon.
interface Props {
  href?: string
  danger?: boolean
  class?: string
  [key: string]: unknown
}
const { href, danger = false, class: className, ...rest } = Astro.props
const Tag = href ? 'a' : 'button'
---

<Tag
  href={href}
  type={href ? undefined : 'button'}
  class:list={[pillSegment(danger ? 'danger' : 'default'), className]}
  {...rest}
>
  <slot />
</Tag>
