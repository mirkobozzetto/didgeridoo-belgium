---
interface Props {
  width: 'md' | '2xl' | '3xl' | '4xl' | '7xl'
  center?: boolean
}
const { width, center = false } = Astro.props

// Classes complètes en littéral : Tailwind ne compile pas les noms dynamiques.
const widths = {
  md: 'max-w-md',
  '2xl': 'max-w-2xl',
  '3xl': 'max-w-3xl',
  '4xl': 'max-w-4xl',
  '7xl': 'max-w-7xl',
}
---

<div
  class:list={[
    'mx-auto flex min-h-[100dvh] flex-col px-5 py-10 sm:px-8',
    widths[width],
    center && 'justify-center',
  ]}
>
  <slot />
</div>
