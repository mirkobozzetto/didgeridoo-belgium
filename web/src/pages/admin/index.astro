---
import Layout from '../../layouts/Layout.astro'
import PageShell from '../../layouts/PageShell.astro'
import AdminHeader from '../../components/admin/AdminHeader.astro'
import AdminLoginForm from '../../components/AdminLoginForm.astro'
import ModerationBoard from '../../components/admin/ModerationBoard.astro'
---

<Layout title="Modération - Administration">
  <PageShell width="3xl" nav active="admin">
    <AdminHeader title="Modération" active="moderation" />
    <AdminLoginForm />
    <ModerationBoard />
  </PageShell>

  <script>
    import { initAdminSession } from '../../lib/admin-session'
    import {
      fetchEvents,
      fetchRecords,
      patchStatus,
      patchRecord,
      deleteRecord,
    } from '../../lib/admin-api'
    import { pendingCard, compactRow, inlineError } from '../../lib/admin-cards'
    import {
      annoncePendingCard,
      reportedRow,
      type ReportedGroup,
    } from '../../lib/admin-annonces-cards'
    import type { AnnonceRecord } from '../../lib/annonces'

    const board = document.getElementById('board') as HTMLDivElement
    const pendingState = document.getElementById(
      'pending-state',
    ) as HTMLDivElement
    const pendingList = document.getElementById(
      'pending-list',
    ) as HTMLDivElement
    const publishedState = document.getElementById(
      'published-state',
    ) as HTMLDivElement
    const publishedList = document.getElementById(
      'published-list',
    ) as HTMLDivElement
    const rejectedState = document.getElementById(
      'rejected-state',
    ) as HTMLDivElement
    const rejectedList = document.getElementById(
      'rejected-list',
    ) as HTMLDivElement

    const session = initAdminSession({ panel: board, onAuth: refreshAll })

    const cardActions = {
      patchStatus: (id: string, body: Record<string, string>) =>
        patchStatus(session, id, body),
      onChange: refreshAll,
    }

    async function loadPending() {
      pendingState.hidden = false
      pendingState.textContent = 'Chargement…'
      pendingList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='pending')",
          'created',
        )
        if (!items) return
        if (!items.length) {
          pendingState.textContent = 'Aucune proposition en attente.'
          return
        }
        pendingState.hidden = true
        for (const ev of items)
          pendingList.appendChild(pendingCard(ev, cardActions))
      } catch {
        pendingState.hidden = false
        pendingState.textContent = 'Impossible de charger les propositions.'
      }
    }

    async function loadPublished() {
      publishedState.hidden = false
      publishedState.textContent = 'Chargement…'
      publishedList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='published')",
          '-updated',
          10,
        )
        if (!items) return
        if (!items.length) {
          publishedState.textContent = 'Aucun événement publié.'
          return
        }
        publishedState.hidden = true
        for (const ev of items) {
          publishedList.appendChild(
            compactRow(ev, {
              label: 'Dépublier',
              run: async () => {
                const err = await patchStatus(session, ev.id, {
                  status: 'pending',
                })
                if (err) {
                  inlineError(publishedList, err)
                  return
                }
                refreshAll()
              },
            }),
          )
        }
      } catch {
        publishedState.hidden = false
        publishedState.textContent = 'Impossible de charger les publiés.'
      }
    }

    async function loadRejected() {
      rejectedState.hidden = false
      rejectedState.textContent = 'Chargement…'
      rejectedList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='rejected')",
          '-updated',
          10,
        )
        if (!items) return
        if (!items.length) {
          rejectedState.textContent = 'Aucun refus.'
          return
        }
        rejectedState.hidden = true
        for (const ev of items) rejectedList.appendChild(compactRow(ev))
      } catch {
        rejectedState.hidden = false
        rejectedState.textContent = 'Impossible de charger les refus.'
      }
    }

    const annPendingState = document.getElementById(
      'ann-pending-state',
    ) as HTMLDivElement
    const annPendingList = document.getElementById(
      'ann-pending-list',
    ) as HTMLDivElement
    const annReportedState = document.getElementById(
      'ann-reported-state',
    ) as HTMLDivElement
    const annReportedList = document.getElementById(
      'ann-reported-list',
    ) as HTMLDivElement

    const annonceActions = {
      patch: (id: string, body: Record<string, string>) =>
        patchRecord(session, 'annonces', id, body),
      onChange: refreshAll,
    }

    async function loadAnnoncesPending() {
      annPendingState.hidden = false
      annPendingState.textContent = 'Chargement…'
      annPendingList.replaceChildren()
      try {
        const items = await fetchRecords<AnnonceRecord>(
          session,
          'annonces',
          "(status='pending')",
          'created',
          200,
          'author',
        )
        if (!items) return
        if (!items.length) {
          annPendingState.textContent = 'Aucune annonce en attente.'
          return
        }
        annPendingState.hidden = true
        for (const ann of items)
          annPendingList.appendChild(annoncePendingCard(ann, annonceActions))
      } catch {
        annPendingState.hidden = false
        annPendingState.textContent = 'Impossible de charger les annonces.'
      }
    }

    interface SignalementRecord {
      id: string
      reason: string
      expand?: { annonce?: AnnonceRecord }
    }

    function groupReports(items: SignalementRecord[]): ReportedGroup[] {
      const groups = new Map<string, ReportedGroup>()
      for (const s of items) {
        const ann = s.expand?.annonce
        if (!ann || ann.status !== 'published') continue
        let group = groups.get(ann.id)
        if (!group) {
          group = { annonce: ann, count: 0, reasons: [], signalementIds: [] }
          groups.set(ann.id, group)
        }
        group.count += 1
        if (s.reason) group.reasons.push(s.reason)
        group.signalementIds.push(s.id)
      }
      return Array.from(groups.values()).sort((a, b) => b.count - a.count)
    }

    async function deleteReports(group: ReportedGroup): Promise<string | null> {
      for (const sid of group.signalementIds) {
        const err = await deleteRecord(session, 'signalements', sid)
        if (err) return err
      }
      return null
    }

    const reportedActions = {
      unpublish: async (group: ReportedGroup) => {
        const err = await patchRecord(session, 'annonces', group.annonce.id, {
          status: 'rejected',
          rejection_reason: 'Annonce signalée par la communauté',
        })
        if (err) return err
        return deleteReports(group)
      },
      ignore: deleteReports,
      onChange: refreshAll,
    }

    async function loadAnnoncesReported() {
      annReportedState.hidden = false
      annReportedState.textContent = 'Chargement…'
      annReportedList.replaceChildren()
      try {
        const items = await fetchRecords<SignalementRecord>(
          session,
          'signalements',
          "id != ''",
          '-created',
          200,
          'annonce',
        )
        if (!items) return
        const groups = groupReports(items)
        if (!groups.length) {
          annReportedState.textContent = 'Aucun signalement.'
          return
        }
        annReportedState.hidden = true
        for (const group of groups)
          annReportedList.appendChild(reportedRow(group, reportedActions))
      } catch {
        annReportedState.hidden = false
        annReportedState.textContent = 'Impossible de charger les signalements.'
      }
    }

    function refreshAll() {
      loadPending()
      loadPublished()
      loadRejected()
      loadAnnoncesPending()
      loadAnnoncesReported()
    }
  </script>
</Layout>
