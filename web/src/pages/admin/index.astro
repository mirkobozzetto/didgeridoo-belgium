---
import Layout from '../../layouts/Layout.astro'
import PageShell from '../../layouts/PageShell.astro'
import AdminHeader from '../../components/admin/AdminHeader.astro'
import AdminLoginForm from '../../components/AdminLoginForm.astro'
import ModerationBoard from '../../components/admin/ModerationBoard.astro'
---

<Layout title="Modération - Administration">
  <PageShell width="3xl" nav active="admin">
    <AdminHeader title="Modération" active="moderation" />
    <AdminLoginForm />
    <ModerationBoard />
  </PageShell>

  <script>
    import { initAdminSession } from '../../lib/admin-session'
    import { fetchEvents, patchStatus } from '../../lib/admin-api'
    import { pendingCard, compactRow, inlineError } from '../../lib/admin-cards'

    const board = document.getElementById('board') as HTMLDivElement
    const pendingState = document.getElementById(
      'pending-state',
    ) as HTMLDivElement
    const pendingList = document.getElementById(
      'pending-list',
    ) as HTMLDivElement
    const publishedState = document.getElementById(
      'published-state',
    ) as HTMLDivElement
    const publishedList = document.getElementById(
      'published-list',
    ) as HTMLDivElement
    const rejectedState = document.getElementById(
      'rejected-state',
    ) as HTMLDivElement
    const rejectedList = document.getElementById(
      'rejected-list',
    ) as HTMLDivElement

    const session = initAdminSession({ panel: board, onAuth: refreshAll })

    const cardActions = {
      patchStatus: (id: string, body: Record<string, string>) =>
        patchStatus(session, id, body),
      onChange: refreshAll,
    }

    async function loadPending() {
      pendingState.hidden = false
      pendingState.textContent = 'Chargement…'
      pendingList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='pending')",
          'created',
        )
        if (!items) return
        if (!items.length) {
          pendingState.textContent = 'Aucune proposition en attente.'
          return
        }
        pendingState.hidden = true
        for (const ev of items)
          pendingList.appendChild(pendingCard(ev, cardActions))
      } catch {
        pendingState.hidden = false
        pendingState.textContent = 'Impossible de charger les propositions.'
      }
    }

    async function loadPublished() {
      publishedState.hidden = false
      publishedState.textContent = 'Chargement…'
      publishedList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='published')",
          '-updated',
          10,
        )
        if (!items) return
        if (!items.length) {
          publishedState.textContent = 'Aucun événement publié.'
          return
        }
        publishedState.hidden = true
        for (const ev of items) {
          publishedList.appendChild(
            compactRow(ev, {
              label: 'Dépublier',
              run: async () => {
                const err = await patchStatus(session, ev.id, {
                  status: 'pending',
                })
                if (err) {
                  inlineError(publishedList, err)
                  return
                }
                refreshAll()
              },
            }),
          )
        }
      } catch {
        publishedState.hidden = false
        publishedState.textContent = 'Impossible de charger les publiés.'
      }
    }

    async function loadRejected() {
      rejectedState.hidden = false
      rejectedState.textContent = 'Chargement…'
      rejectedList.replaceChildren()
      try {
        const items = await fetchEvents(
          session,
          "(status='rejected')",
          '-updated',
          10,
        )
        if (!items) return
        if (!items.length) {
          rejectedState.textContent = 'Aucun refus.'
          return
        }
        rejectedState.hidden = true
        for (const ev of items) rejectedList.appendChild(compactRow(ev))
      } catch {
        rejectedState.hidden = false
        rejectedState.textContent = 'Impossible de charger les refus.'
      }
    }

    function refreshAll() {
      loadPending()
      loadPublished()
      loadRejected()
    }
  </script>
</Layout>
