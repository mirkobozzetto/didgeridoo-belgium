---
import Layout from '../layouts/Layout.astro'
import PageShell from '../layouts/PageShell.astro'
import { btn } from '../lib/button-styles'
---

<Layout
  title="Calendrier des événements — Didgeridoo Belgique"
  description="Tous les stages, concerts et rencontres à venir de la communauté belge du didgeridoo."
>
  <PageShell width="4xl" nav active="calendrier">
    <section
      class="flex flex-wrap items-end justify-between gap-x-6 gap-y-5 py-7 sm:py-9"
    >
      <div>
        <p
          class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
        >
          Agenda
        </p>
        <h1
          class="balance mt-1.5 text-[clamp(2rem,4.5vw,3rem)] font-extrabold leading-[1.05] tracking-[-0.035em] text-stone-900"
        >
          Les prochains événements
        </h1>
        <p
          class="pretty mt-3 max-w-xl text-[14px] leading-[1.7] text-stone-600"
        >
          Stages, concerts et rencontres autour du didgeridoo et de la culture
          aborigène, en Belgique.
        </p>
      </div>

      <div id="ics" hidden class="relative">
        <button
          type="button"
          id="ics-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-[12.5px] font-semibold text-stone-600 ring-1 ring-inset ring-stone-900/10 transition hover:text-brand-700 hover:ring-brand-300"
        >
          <svg
            class="h-4 w-4 text-brand-600"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M5.75 3a.75.75 0 0 0-.75.75V4h-.5A2.5 2.5 0 0 0 2 6.5v8A2.5 2.5 0 0 0 4.5 17h11a2.5 2.5 0 0 0 2.5-2.5v-8A2.5 2.5 0 0 0 15.5 4H15v-.25a.75.75 0 0 0-1.5 0V4h-7v-.25A.75.75 0 0 0 5.75 3ZM3.5 8h13v6.5a1 1 0 0 1-1 1h-11a1 1 0 0 1-1-1V8Z"
            ></path>
          </svg>
          Ajouter à mon agenda
        </button>
        <div
          id="ics-menu"
          hidden
          class="absolute right-0 top-full z-20 mt-2 w-64 overflow-hidden rounded-xl bg-white py-1.5 shadow-pop ring-1 ring-stone-900/5"
        >
        </div>
      </div>
    </section>

    <section id="events" class="min-h-0 flex-1 pb-10">
      <div id="filters" hidden class="mb-8 max-w-full overflow-x-auto">
        <div data-filter-pill>
          <button type="button" data-cat="all">Tous</button>
          <button type="button" data-cat="stage">Stage</button>
          <button type="button" data-cat="concert">Concert</button>
          <button type="button" data-cat="festival">Festival</button>
          <button type="button" data-cat="rencontre">Rencontre</button>
          <button type="button" data-cat="autre">Autre</button>
        </div>
      </div>

      <div id="loading" class="py-12 text-center text-[13px] text-stone-400">
        Chargement des événements…
      </div>

      <div
        id="empty"
        hidden
        class="mx-auto max-w-md rounded-2xl bg-white p-8 text-center shadow-card ring-1 ring-stone-900/5"
      >
        <img
          src="/didge-placeholder.webp"
          alt=""
          width="112"
          height="112"
          class="mx-auto mb-4 h-28 w-28 rounded-2xl object-cover ring-1 ring-inset ring-stone-900/5"
        />
        <p class="text-[15px] font-semibold text-stone-900">
          Aucun événement à venir pour l'instant
        </p>
        <p
          class="pretty mx-auto mt-1.5 max-w-sm text-[13px] leading-relaxed text-stone-500"
        >
          Rejoins la communauté sur la page d'accueil pour être prévenu dès
          qu'un stage ou un concert est annoncé.
        </p>
        <a href="/" class:list={[btn('primary', 'md'), 'mt-5']}>
          Rejoindre la communauté
        </a>
      </div>

      <div
        id="error"
        hidden
        class="rounded-2xl border border-red-200 bg-red-50 px-6 py-5 text-center text-[13px] text-red-700"
      >
        Impossible de charger les événements. Réessaie dans un instant.
      </div>

      <div id="list" hidden class="flex flex-col gap-10"></div>
    </section>

    <footer
      class="mt-auto border-t border-stone-900/[0.07] pb-1 pt-4 text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400"
    >
      <div class="flex items-center justify-between">
        <span>Didgeridoo &amp; culture aborigène</span>
        <span
          >Belgique · <a href="/" class="text-brand-600 hover:text-brand-700"
            >Accueil</a
          ></span
        >
      </div>
      <div class="mt-2 flex items-center gap-3 normal-case tracking-normal">
        <a href="/confidentialite" class="hover:text-stone-600"
          >Confidentialité</a
        >
        <span>·</span>
        <a href="/mentions-legales" class="hover:text-stone-600"
          >Mentions légales</a
        >
      </div>
    </footer>
  </PageShell>

  <script>
    import {
      pillGroup,
      pillSegment,
      pillSegmentActive,
      pillSep,
    } from '../lib/pill-styles'

    type Session = { date: string; start: string; end: string | null }

    type EventRecord = {
      id: string
      title: string
      slug: string
      start: string
      end?: string
      location?: string
      description?: string
      poster?: string
      category?: string
      sessions?: Session[]
    }

    const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? '').replace(/\/$/, '')

    const CATEGORIES: Record<string, string> = {
      stage: 'Stage',
      concert: 'Concert',
      festival: 'Festival',
      rencontre: 'Rencontre',
      autre: 'Autre',
    }

    const CHIP_ON = pillSegmentActive()
    const CHIP_OFF = pillSegment()

    const filterPill = document.querySelector(
      '[data-filter-pill]',
    ) as HTMLDivElement
    filterPill.className = pillGroup()
    for (const chip of Array.from(filterPill.querySelectorAll('button')).slice(
      1,
    )) {
      const sep = document.createElement('span')
      sep.className = pillSep()
      sep.setAttribute('aria-hidden', 'true')
      filterPill.insertBefore(sep, chip)
    }

    const loadingEl = document.getElementById('loading') as HTMLDivElement
    const emptyEl = document.getElementById('empty') as HTMLDivElement
    const errorEl = document.getElementById('error') as HTMLDivElement
    const listEl = document.getElementById('list') as HTMLDivElement
    const filtersEl = document.getElementById('filters') as HTMLDivElement
    const icsEl = document.getElementById('ics') as HTMLDivElement

    let allEvents: EventRecord[] = []

    const dayFmt = new Intl.DateTimeFormat('fr-BE', {
      weekday: 'short',
      day: 'numeric',
      month: 'short',
    })
    const timeFmt = new Intl.DateTimeFormat('fr-BE', {
      hour: '2-digit',
      minute: '2-digit',
    })
    const monthFmt = new Intl.DateTimeFormat('fr-BE', {
      month: 'long',
      year: 'numeric',
    })

    // Filtre Pocketbase : format UTC "YYYY-MM-DD HH:mm:ss".
    function nowUtcFilter(): string {
      return new Date().toISOString().slice(0, 19).replace('T', ' ')
    }

    // Pocketbase renvoie la date avec un espace, pas un ISO strict.
    function parseDate(raw: string): Date {
      return new Date(raw.replace(' ', 'T'))
    }

    function stripHtml(s: string): string {
      return s
        .replace(/<[^>]*>/g, ' ')
        .replace(/&nbsp;/g, ' ')
        .replace(/&amp;/g, '&')
        .replace(/\s+/g, ' ')
        .trim()
    }

    function posterUrl(ev: EventRecord): string | null {
      if (!ev.poster) return null
      return `${API_BASE}/pb/api/files/events/${ev.id}/${ev.poster}`
    }

    function capitalize(s: string): string {
      return s.charAt(0).toUpperCase() + s.slice(1)
    }

    function eventCard(ev: EventRecord): HTMLAnchorElement {
      const a = document.createElement('a')
      a.href = `/evenements/${ev.slug}`
      a.className =
        'group flex gap-4 rounded-2xl bg-white p-3.5 ring-1 ring-stone-900/5 shadow-card transition hover:shadow-card-hover hover:ring-brand-200'

      const thumb = document.createElement('div')
      thumb.className =
        'relative h-24 w-24 shrink-0 overflow-hidden rounded-xl bg-brand-100 ring-1 ring-inset ring-stone-900/5 sm:h-28 sm:w-28'
      const img = document.createElement('img')
      const src = posterUrl(ev)
      img.src = src ?? '/didge-placeholder.webp'
      img.alt = src ? `Affiche : ${ev.title}` : ''
      img.loading = 'lazy'
      img.className = 'h-full w-full object-cover'
      thumb.appendChild(img)

      const body = document.createElement('div')
      body.className = 'flex min-w-0 flex-col justify-center py-1'

      const start = parseDate(ev.start)
      const dateLine = document.createElement('p')
      dateLine.className =
        'text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-600'
      dateLine.textContent = `${capitalize(dayFmt.format(start))} · ${timeFmt.format(start)}`

      body.appendChild(dateLine)

      const extra =
        Array.isArray(ev.sessions) && ev.sessions.length > 1
          ? ev.sessions.length - 1
          : 0
      if (extra > 0) {
        const more = document.createElement('p')
        more.className = 'mt-0.5 text-[12px] text-stone-400'
        more.textContent = `+${extra} autre${extra > 1 ? 's' : ''} date${extra > 1 ? 's' : ''}`
        body.appendChild(more)
      }

      const title = document.createElement('h2')
      title.className =
        'mt-1 truncate text-[16px] font-bold leading-snug tracking-tight text-stone-900'
      title.textContent = ev.title

      body.appendChild(title)

      const excerpt = ev.description ? stripHtml(ev.description) : ''
      if (excerpt) {
        const desc = document.createElement('p')
        desc.className =
          'mt-1 line-clamp-2 text-[12.5px] leading-relaxed text-stone-500'
        desc.textContent = excerpt
        body.appendChild(desc)
      }

      if (ev.category && CATEGORIES[ev.category]) {
        const badge = document.createElement('span')
        badge.className =
          'mt-1.5 inline-flex w-fit rounded-full bg-stone-100 px-2.5 py-0.5 text-[10.5px] font-semibold uppercase tracking-[0.1em] text-stone-500'
        badge.textContent = CATEGORIES[ev.category]
        body.appendChild(badge)
      }

      if (ev.location) {
        const loc = document.createElement('p')
        loc.className = 'mt-0.5 truncate text-[13px] text-stone-500'
        loc.textContent = ev.location
        body.appendChild(loc)
      }

      a.append(thumb, body)
      return a
    }

    function renderList(events: EventRecord[]) {
      listEl.replaceChildren()

      if (events.length === 0) {
        const msg = document.createElement('p')
        msg.className = 'py-10 text-center text-[13px] text-stone-400'
        msg.textContent = 'Aucun événement dans cette catégorie.'
        listEl.appendChild(msg)
        listEl.hidden = false
        return
      }

      const groups = new Map<string, { label: string; items: EventRecord[] }>()
      for (const ev of events) {
        const d = parseDate(ev.start)
        const key = `${d.getFullYear()}-${d.getMonth()}`
        if (!groups.has(key))
          groups.set(key, { label: capitalize(monthFmt.format(d)), items: [] })
        groups.get(key)!.items.push(ev)
      }

      for (const { label, items } of groups.values()) {
        const section = document.createElement('div')
        const heading = document.createElement('h2')
        heading.className =
          'mb-4 border-b border-stone-900/10 pb-2 text-[12px] font-semibold uppercase tracking-[0.16em] text-stone-400'
        heading.textContent = label
        section.appendChild(heading)

        const cards = document.createElement('div')
        cards.className = 'flex flex-col gap-3'
        for (const ev of items) cards.appendChild(eventCard(ev))
        section.appendChild(cards)
        listEl.appendChild(section)
      }
      listEl.hidden = false
    }

    function applyFilter(cat: string) {
      for (const chip of Array.from(filtersEl.querySelectorAll('button'))) {
        const on = chip.dataset.cat === cat
        chip.className = on ? CHIP_ON : CHIP_OFF
      }
      renderList(
        cat === 'all'
          ? allEvents
          : allEvents.filter((ev) => ev.category === cat),
      )
    }

    // Menu « Ajouter à mon agenda » : liens profonds un-clic par plateforme,
    // copie du lien en dernier recours (le cid= Google échoue parfois).
    function setupIcsMenu() {
      const trigger = document.getElementById(
        'ics-trigger',
      ) as HTMLButtonElement
      const menu = document.getElementById('ics-menu') as HTMLDivElement

      const icsUrl = `${location.host}/calendrier.ics`
      const webcal = `webcal://${icsUrl}`
      const item =
        'block w-full px-4 py-2 text-left text-[13px] text-stone-600 transition-colors hover:bg-stone-50 hover:text-stone-900'

      const apple = { label: 'Apple Calendar', href: webcal, blank: false }
      const google = {
        label: 'Google Agenda',
        href: `https://calendar.google.com/calendar/r?cid=${webcal}`,
        blank: true,
      }
      const outlook = {
        label: 'Outlook',
        href: `https://outlook.live.com/calendar/0/addfromweb?url=${webcal}&name=${encodeURIComponent('Didgeridoo Belgique')}`,
        blank: true,
      }
      const isApple = /Mac|iPhone|iPad/.test(navigator.userAgent)
      const links = isApple
        ? [apple, google, outlook]
        : [google, apple, outlook]

      for (const l of links) {
        const a = document.createElement('a')
        a.href = l.href
        a.textContent = l.label
        a.className = item
        if (l.blank) {
          a.target = '_blank'
          a.rel = 'noopener'
        }
        menu.appendChild(a)
      }

      const sep = document.createElement('div')
      sep.className = 'my-1.5 border-t border-stone-900/10'
      menu.appendChild(sep)

      const copy = document.createElement('button')
      copy.type = 'button'
      copy.textContent = 'Copier le lien'
      copy.className = `${item} text-stone-400`
      const copyUrl = `https://${icsUrl}`
      // clipboard.writeText peut rester pendu (permission) : timeout + repli
      // execCommand, puis feedback dans tous les cas.
      const fallbackCopy = () => {
        const ta = document.createElement('textarea')
        ta.value = copyUrl
        ta.setAttribute('readonly', '')
        ta.style.position = 'fixed'
        ta.style.opacity = '0'
        document.body.appendChild(ta)
        ta.select()
        document.execCommand('copy')
        ta.remove()
      }
      copy.addEventListener('click', async () => {
        try {
          await Promise.race([
            navigator.clipboard.writeText(copyUrl),
            new Promise((_, reject) => setTimeout(reject, 400)),
          ])
        } catch {
          fallbackCopy()
        }
        copy.textContent = 'Lien copié'
        setTimeout(() => {
          copy.textContent = 'Copier le lien'
        }, 2000)
      })
      menu.appendChild(copy)

      const close = () => {
        menu.hidden = true
        trigger.setAttribute('aria-expanded', 'false')
      }
      trigger.addEventListener('click', (e) => {
        e.stopPropagation()
        menu.hidden = !menu.hidden
        trigger.setAttribute('aria-expanded', String(!menu.hidden))
      })
      document.addEventListener('click', (e) => {
        if (!menu.hidden && !menu.contains(e.target as Node)) close()
      })
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close()
      })
    }

    function render(events: EventRecord[]) {
      loadingEl.hidden = true
      if (events.length === 0) {
        emptyEl.hidden = false
        return
      }

      allEvents = events
      filtersEl.hidden = false
      icsEl.hidden = false
      setupIcsMenu()
      for (const chip of Array.from(filtersEl.querySelectorAll('button'))) {
        chip.addEventListener('click', () =>
          applyFilter(chip.dataset.cat ?? 'all'),
        )
      }
      applyFilter('all')
    }

    async function load() {
      const filter = encodeURIComponent(
        `(status='published' && start >= '${nowUtcFilter()}')`,
      )
      const url = `${API_BASE}/pb/api/collections/events/records?filter=${filter}&sort=start&perPage=200`
      try {
        const res = await fetch(url)
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        const json = await res.json()
        render((json.items ?? []) as EventRecord[])
      } catch {
        loadingEl.hidden = true
        errorEl.hidden = false
      }
    }

    load()
  </script>
</Layout>
