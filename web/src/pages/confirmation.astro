---
import Layout from '../layouts/Layout.astro'
import PageShell from '../layouts/PageShell.astro'
import Brand from '../components/Brand.astro'
import { btn } from '../lib/button-styles'
---

<Layout title="Inscription confirmée — Didgeridoo Belgique">
  <PageShell width="md" center>
    <header class="pb-6 text-center">
      <Brand />
    </header>

    <div
      class="relative overflow-hidden rounded-2xl bg-white p-6 text-center shadow-card ring-1 ring-stone-900/5"
    >
      <span
        class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
      ></span>

      <p
        class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
      >
        Bienvenue
      </p>
      <h1
        class="balance mt-1.5 text-[19px] font-bold leading-snug tracking-tight text-stone-900"
      >
        Inscription confirmée
      </h1>
      <p class="pretty mt-1.5 text-[13px] leading-relaxed text-stone-600">
        Tu recevras les prochains événements par e-mail. Dernière étape&nbsp;:
        scanne le QR code depuis ton téléphone, ou clique sur le bouton pour
        rejoindre le groupe&nbsp;WhatsApp.
      </p>

      <div
        class="mt-5 flex items-center justify-center rounded-xl bg-stone-50 py-5 ring-1 ring-inset ring-stone-900/5"
      >
        <div
          id="qr"
          class="rounded-lg bg-white p-2 shadow-sm ring-1 ring-stone-900/5"
        >
          <!-- QR code injecté ici -->
        </div>
      </div>

      <a
        id="wa-link"
        href="#"
        target="_blank"
        rel="noopener"
        class:list={[btn('whatsapp', 'lg'), 'mt-4 w-full']}
      >
        <svg
          viewBox="0 0 24 24"
          class="h-[22px] w-[22px]"
          fill="currentColor"
          aria-hidden="true"
          ><path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
          ></path></svg
        >
        Rejoindre le groupe WhatsApp
      </a>
    </div>

    <p class="mt-6 text-center text-[11.5px] text-stone-400">
      <a href="/" class="hover:text-stone-600">Retour à l'accueil</a>
    </p>
  </PageShell>

  <script>
    import QRCode from 'qrcode'

    const qrEl = document.getElementById('qr') as HTMLDivElement
    const waLink = document.getElementById('wa-link') as HTMLAnchorElement

    const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? '').replace(/\/$/, '')

    async function load() {
      try {
        const res = await fetch(`${API_BASE}/api/whatsapp`)
        const json = await res.json()
        const url = typeof json.url === 'string' ? json.url : ''
        if (!url) throw new Error('no url')

        waLink.href = url
        const dataUrl = await QRCode.toDataURL(url, {
          width: 150,
          margin: 1,
          color: { dark: '#1c1917', light: '#ffffff' },
        })
        const img = document.createElement('img')
        img.src = dataUrl
        img.alt = 'QR code du groupe WhatsApp'
        img.width = 150
        img.height = 150
        qrEl.replaceChildren(img)
      } catch {
        qrEl.parentElement!.hidden = true
      }
    }

    load()
  </script>
</Layout>
