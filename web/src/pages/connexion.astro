---
import Layout from '../layouts/Layout.astro'
import PageShell from '../layouts/PageShell.astro'
import Brand from '../components/Brand.astro'
---

<Layout title="Espace organisateur — Didgeridoo Belgique">
  <PageShell width="md" center>
    <header class="pb-6 text-center">
      <Brand />
    </header>

    <div
      class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-card ring-1 ring-stone-900/5"
    >
      <span
        class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
      ></span>

      <p
        class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
      >
        Espace organisateur
      </p>
      <h1
        id="heading"
        class="balance mt-1.5 text-[19px] font-bold leading-snug tracking-tight text-stone-900"
      >
        Connexion
      </h1>
      <p class="pretty mt-1.5 text-[13px] leading-relaxed text-stone-600">
        Propose un événement à la communauté et suis son statut.
      </p>

      <form id="auth-form" novalidate class="mt-5 flex flex-col gap-4">
        <label id="name-field" hidden class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Nom</span
          >
          <input
            type="text"
            name="name"
            autocomplete="name"
            placeholder="Ton nom"
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >E-mail</span
          >
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="toi@exemple.be"
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Mot de passe</span
          >
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            placeholder="Ton mot de passe"
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <div class="hp" aria-hidden="true">
          <label
            >Site web<input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
            /></label
          >
        </div>

        <div
          id="error"
          hidden
          class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-[13px] text-red-700"
        >
        </div>

        <div
          id="notice"
          hidden
          class="rounded-xl border border-stone-200 bg-stone-50 px-4 py-3 text-[13px] text-stone-700"
        >
        </div>

        <button
          type="submit"
          class="group/btn mt-1 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 px-5 py-3.5 text-[15px] font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px disabled:opacity-60"
        >
          <span id="submit-label">Se connecter</span>
        </button>
      </form>

      <p class="mt-4 text-center text-[13px] text-stone-500">
        <span id="toggle-text">Pas encore de compte&nbsp;?</span>
        <button
          id="toggle"
          type="button"
          class="font-semibold text-brand-600 hover:text-brand-700"
          >Créer un compte</button
        >
      </p>
      <p class="mt-2 text-center text-[12.5px] text-stone-400">
        <button
          id="forgot"
          type="button"
          class="hover:text-stone-600 underline underline-offset-2"
          >Mot de passe oublié&nbsp;?</button
        >
      </p>
    </div>

    <p class="mt-6 text-center text-[11.5px] text-stone-400">
      <a href="/" class="hover:text-stone-600">Retour à l'accueil</a>
    </p>
  </PageShell>

  <script>
    import { pb, getAuth, isAdmin, loginBoth } from '../lib/pb'

    if (getAuth()) location.replace('/mes-propositions')
    else if (isAdmin()) location.replace('/admin')

    const form = document.getElementById('auth-form') as HTMLFormElement
    const errorEl = document.getElementById('error') as HTMLDivElement
    const noticeEl = document.getElementById('notice') as HTMLDivElement
    const forgot = document.getElementById('forgot') as HTMLButtonElement
    const nameField = document.getElementById('name-field') as HTMLLabelElement
    const nameInput = nameField.querySelector('input') as HTMLInputElement
    const passwordInput = form.querySelector(
      'input[name="password"]',
    ) as HTMLInputElement
    const heading = document.getElementById('heading') as HTMLHeadingElement
    const submitLabel = document.getElementById(
      'submit-label',
    ) as HTMLSpanElement
    const toggleText = document.getElementById('toggle-text') as HTMLSpanElement
    const toggle = document.getElementById('toggle') as HTMLButtonElement
    const button = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement

    let mode: 'login' | 'signup' = 'login'

    function applyMode() {
      const signup = mode === 'signup'
      nameField.hidden = !signup
      nameInput.required = signup
      passwordInput.autocomplete = signup ? 'new-password' : 'current-password'
      passwordInput.placeholder = signup
        ? '8 caractères minimum'
        : 'Ton mot de passe'
      heading.textContent = signup ? 'Créer un compte' : 'Connexion'
      submitLabel.textContent = signup ? 'Créer mon compte' : 'Se connecter'
      toggleText.textContent = signup
        ? 'Déjà un compte ?'
        : 'Pas encore de compte ?'
      toggle.textContent = signup ? 'Se connecter' : 'Créer un compte'
      errorEl.hidden = true
    }

    toggle.addEventListener('click', () => {
      mode = mode === 'login' ? 'signup' : 'login'
      applyMode()
    })

    function showError(msg: string) {
      errorEl.hidden = false
      errorEl.textContent = msg
      noticeEl.hidden = true
    }

    function showNotice(msg: string) {
      noticeEl.hidden = false
      noticeEl.textContent = msg
      errorEl.hidden = true
    }

    forgot.addEventListener('click', async () => {
      const email = String(new FormData(form).get('email') ?? '').trim()
      if (!email) {
        showError("Renseigne d'abord ton e-mail, puis reclique.")
        return
      }
      try {
        await pb('/api/collections/users/request-password-reset', {
          method: 'POST',
          body: { email },
        })
      } catch {
        // Réponse identique que le compte existe ou non : rien à divulguer.
      }
      showNotice(
        'Si un compte existe pour cet e-mail, un lien de réinitialisation vient de partir. Vérifie ta boîte.',
      )
    })

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const data = new FormData(form)
      if (String(data.get('website') ?? '')) return

      const email = String(data.get('email') ?? '').trim()
      const password = String(data.get('password') ?? '')
      const name = String(data.get('name') ?? '').trim()

      if (!email || !password) {
        showError('Merci de remplir tous les champs obligatoires.')
        return
      }
      if (mode === 'signup' && password.length < 8) {
        showError('Le mot de passe doit faire au moins 8 caractères.')
        return
      }

      button.disabled = true
      errorEl.hidden = true

      try {
        if (mode === 'signup') {
          await pb('/api/collections/users/records', {
            method: 'POST',
            body: {
              email,
              password,
              passwordConfirm: password,
              name: name || email.split('@')[0],
            },
          })
          await pb('/api/collections/users/request-verification', {
            method: 'POST',
            body: { email },
          })
          form.reset()
          mode = 'login'
          applyMode()
          showNotice(
            'Compte créé. Un e-mail de confirmation vient de partir : clique sur le lien pour activer ton compte, puis connecte-toi.',
          )
          return
        }

        const { organizer, admin } = await loginBoth(email, password)
        if (!organizer && !admin) {
          showError(
            'Identifiants invalides, ou compte pas encore activé (vérifie ta boîte mail, pense au spam).',
          )
          return
        }
        location.replace(organizer ? '/mes-propositions' : '/admin')
      } catch (err) {
        const status = (err as { status?: number })?.status
        if (mode === 'signup' && status === 400) {
          showError(
            'Cet e-mail est déjà utilisé ou les données sont invalides.',
          )
        } else {
          showError('Une erreur est survenue. Réessaie.')
        }
      } finally {
        button.disabled = false
      }
    })
  </script>

  <style>
    .hp {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
  </style>
</Layout>
