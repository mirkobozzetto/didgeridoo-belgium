---
import Layout from '../layouts/Layout.astro'
import { btn } from '../lib/button-styles'

const SITE_URL = 'https://didgeridoo.top'
const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Didgeridoo Belgique',
    url: SITE_URL,
    logo: `${SITE_URL}/hero.jpeg`,
    description:
      'Communauté belge du didgeridoo et de la culture aborigène : stages, concerts, rencontres et petites annonces.',
    areaServed: { '@type': 'Country', name: 'Belgique' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Didgeridoo Belgique',
    url: SITE_URL,
  },
])
---

<Layout>
  <script type="application/ld+json" is:inline set:html={jsonLd} />
  <div class="mx-auto max-w-7xl px-5 pb-12 sm:px-8">
    <!-- Écran d'accueil : plein viewport, hero + formulaire -->
    <div class="flex min-h-[100dvh] flex-col py-4 lg:h-[100dvh]">
      <!-- Barre haute -->
      <header
        class="flex items-center justify-between border-b border-stone-900/10 pb-4"
      >
        <span class="text-[13.5px] font-extrabold tracking-[0.08em]">
          <span class="text-stone-900">didge</span><span
            class="text-flag-yellow">ridoo</span
          ><span class="text-flag-red">.top</span>
        </span>
        <nav class="hidden items-center gap-5 md:flex">
          <a
            href="/calendrier"
            class="text-[11px] font-medium uppercase tracking-[0.18em] text-stone-400 transition-colors hover:text-brand-600"
          >
            Calendrier des événements&nbsp;→
          </a>
          <a
            href="/annonces"
            class="text-[11px] font-medium uppercase tracking-[0.18em] text-stone-400 transition-colors hover:text-brand-600"
          >
            Annonces&nbsp;→
          </a>
          <a href="/connexion" class={btn('outline', 'xs')}> Se connecter </a>
        </nav>
        <span
          class="inline-flex items-center gap-2 rounded-full bg-brand-100 py-1 pl-2.5 pr-3 text-[10.5px] font-semibold uppercase tracking-[0.14em] text-brand-700 ring-1 ring-inset ring-brand-200/70"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-500 opacity-60"
            ></span>
            <span
              class="relative inline-flex h-1.5 w-1.5 rounded-full bg-brand-600"
            ></span>
          </span>
          🇧🇪 Communauté belge
        </span>
      </header>

      <!-- Titre éditorial -->
      <section
        class="grid items-end gap-x-12 gap-y-3 py-7 sm:py-9 lg:grid-cols-[1fr_19rem]"
      >
        <h1
          class="balance text-[clamp(2.4rem,5.2vw,3.8rem)] font-extrabold leading-[1.05] tracking-[-0.035em] text-stone-900"
        >
          Stages, concerts, didgeridoo&nbsp;:
          <span class="relative inline-block text-brand-600">
            c'est ici
            <svg
              class="absolute -bottom-2 left-0 w-full"
              viewBox="0 0 200 9"
              fill="none"
              preserveAspectRatio="none"
              aria-hidden="true"
            >
              <path
                d="M2 7C60 2.5 140 2.5 198 6"
                stroke="var(--color-brand-300)"
                stroke-width="4"
                stroke-linecap="round"></path>
            </svg>
          </span>
        </h1>
        <div class="border-stone-900/10 lg:border-l lg:pb-1.5 lg:pl-6">
          <p class="pretty text-[14px] leading-[1.7] text-stone-600">
            La communauté belge du didgeridoo. Reçois chaque stage, concert et
            rencontre en avant&#8209;première, et rejoins le
            groupe&nbsp;WhatsApp.
          </p>
        </div>
      </section>

      <!-- Bande image + carte -->
      <section class="relative min-h-0 flex-1 pb-1">
        <div
          class="relative h-64 overflow-hidden rounded-3xl ring-1 ring-stone-900/10 sm:h-80 lg:h-full"
        >
          <img
            src="/hero.jpeg"
            alt="Joueur de didgeridoo au coucher du soleil"
            class="h-full w-full object-cover object-[center_58%]"
          />
          <div
            class="grain pointer-events-none absolute inset-0 opacity-[0.13] mix-blend-overlay"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-white/15"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-brand-950/25 to-transparent"
          >
          </div>
        </div>

        <!-- Carte formulaire -->
        <form
          id="subscribe"
          novalidate
          class="relative mt-4 overflow-hidden rounded-2xl bg-white p-6 shadow-card ring-1 ring-stone-900/5 transition-shadow duration-500 hover:shadow-card-hover lg:absolute lg:top-1/2 lg:left-7 lg:mt-0 lg:-translate-y-1/2 lg:w-[22.5rem] lg:bg-white/95 lg:backdrop-blur"
        >
          <span
            class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
          ></span>
          <!-- Honeypot : invisible pour un humain, rempli par les bots. -->
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            class="pointer-events-none absolute -left-[9999px] h-0 w-0 opacity-0"
          />
          <p
            class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
          >
            Rejoindre
          </p>
          <h2
            class="balance mt-1.5 text-[19px] font-bold leading-snug tracking-tight text-stone-900"
          >
            Les prochains événements, en&nbsp;premier
          </h2>

          <div class="mt-5 flex flex-col gap-4">
            <div class="grid grid-cols-2 gap-5">
              <label class="field block pb-2">
                <span
                  class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
                  >Prénom</span
                >
                <input
                  type="text"
                  name="firstname"
                  autocomplete="given-name"
                  placeholder="Ton prénom"
                  class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
                />
              </label>
              <label class="field block pb-2">
                <span
                  class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
                  >Pays <span class="normal-case tracking-normal text-stone-300"
                    >(facultatif)</span
                  ></span
                >
                <input
                  type="text"
                  name="country"
                  autocomplete="country-name"
                  placeholder="Belgique"
                  class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
                />
              </label>
            </div>

            <label class="field block pb-2">
              <span
                class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
                >E-mail</span
              >
              <input
                type="email"
                name="email"
                required
                autocomplete="email"
                placeholder="toi@exemple.be"
                class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
              />
            </label>

            <label
              class="flex items-start gap-2.5 text-[12px] leading-snug text-stone-500"
            >
              <input
                type="checkbox"
                name="consent"
                required
                class="mt-0.5 h-4 w-4 shrink-0 rounded border-stone-300 accent-brand-600"
              />
              <span class="pretty"
                >J'accepte de recevoir les annonces d'événements par
                e&#8209;mail. Désinscription en un&nbsp;clic.</span
              >
            </label>

            <div
              id="error"
              hidden
              class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-[13px] text-red-700"
            >
            </div>

            <button
              type="submit"
              class:list={[btn('primary', 'lg'), 'group/btn mt-1 w-full']}
            >
              Je rejoins la communauté
              <svg
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-4 w-4 transition-transform duration-300 group-hover/btn:translate-x-1"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M2 10a.75.75 0 01.75-.75h12.19l-3.72-3.72a.75.75 0 111.06-1.06l5 5a.75.75 0 010 1.06l-5 5a.75.75 0 11-1.06-1.06l3.72-3.72H2.75A.75.75 0 012 10z"
                  clip-rule="evenodd"></path>
              </svg>
            </button>

            <p class="text-center text-[11.5px] text-stone-400">
              Zéro spam · désinscription en un clic
            </p>
          </div>
        </form>

        <!-- Écran de succès : remplace la carte formulaire -->
        <div
          id="success"
          hidden
          class="relative mt-4 overflow-hidden rounded-2xl bg-white p-6 text-center shadow-card ring-1 ring-stone-900/5 lg:absolute lg:top-1/2 lg:left-7 lg:mt-0 lg:-translate-y-1/2 lg:w-[22.5rem] lg:bg-white/95 lg:backdrop-blur"
        >
          <span
            class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
          ></span>
          <p
            class="text-left text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
          >
            Presque fini
          </p>
          <h2
            class="balance mt-1.5 text-left text-[19px] font-bold leading-snug tracking-tight text-stone-900"
          >
            Vérifie ta boîte mail
          </h2>
          <p
            class="pretty mt-1.5 text-left text-[13px] leading-relaxed text-stone-600"
          >
            On vient de t'envoyer un e-mail de confirmation. Clique sur le lien
            qu'il contient pour valider ton inscription et accéder au
            groupe&nbsp;WhatsApp.
          </p>
          <p class="mt-4 text-left text-[11.5px] text-stone-400">
            Rien reçu&nbsp;? Regarde dans tes spams, ou réessaie dans une
            minute.
          </p>
        </div>
      </section>
    </div>

    <!-- Agenda : prochains événements -->
    <section class="border-t border-stone-900/[0.07] py-12 sm:py-16">
      <div>
        <p
          class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
        >
          Agenda
        </p>
        <h2
          class="balance mt-1.5 text-[clamp(1.7rem,3.6vw,2.4rem)] font-extrabold leading-[1.05] tracking-[-0.03em] text-stone-900"
        >
          Prochains événements
        </h2>
      </div>

      <div id="ev-loading" class="py-12 text-center text-[13px] text-stone-400">
        Chargement des événements…
      </div>

      <div
        id="ev-empty"
        hidden
        class="mt-8 rounded-2xl bg-white p-8 text-center ring-1 ring-stone-900/5"
      >
        <p class="text-[15px] font-semibold text-stone-900">
          Les prochains stages et concerts arrivent ici
        </p>
        <a href="/calendrier" class:list={[btn('primary', 'md'), 'mt-5']}>
          Voir le calendrier
        </a>
      </div>

      <div
        id="ev-error"
        hidden
        class="mt-8 rounded-2xl border border-red-200 bg-red-50 px-6 py-5 text-center text-[13px] text-red-700"
      >
        Impossible de charger les événements. Réessaie dans un instant.
      </div>

      <div id="ev-grid" hidden class="mt-8 grid gap-4 sm:grid-cols-2"></div>

      <div id="ev-cta" hidden class="mt-10 text-center">
        <a href="/calendrier" class={btn('outline', 'md')}>
          Voir tout le calendrier
          <svg
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M2 10a.75.75 0 01.75-.75h12.19l-3.72-3.72a.75.75 0 111.06-1.06l5 5a.75.75 0 010 1.06l-5 5a.75.75 0 11-1.06-1.06l3.72-3.72H2.75A.75.75 0 012 10z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
      </div>

      <p class="mt-8 text-center text-[12px] text-stone-400">
        Tu organises un stage ou un concert ?
        <a
          href="/proposer"
          class="font-semibold text-brand-600 hover:text-brand-700"
          >Propose ton événement</a
        >
      </p>
    </section>

    <!-- Pied micro -->
    <footer
      class="border-t border-stone-900/[0.07] pb-1 pt-4 text-[11px] font-medium uppercase tracking-[0.16em] text-stone-400"
    >
      <div class="flex items-center justify-between">
        <span>Didgeridoo &amp; culture aborigène</span>
        <span>Belgique · <span class="text-brand-600">WhatsApp</span></span>
      </div>
      <div class="mt-2 flex items-center gap-3 normal-case tracking-normal">
        <a href="/confidentialite" class="hover:text-stone-600"
          >Confidentialité</a
        >
        <span>·</span>
        <a href="/mentions-legales" class="hover:text-stone-600"
          >Mentions légales</a
        >
      </div>
    </footer>
  </div>

  <script>
    const form = document.getElementById('subscribe') as HTMLFormElement
    const successEl = document.getElementById('success') as HTMLDivElement
    const errorEl = document.getElementById('error') as HTMLDivElement
    const button = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement

    // Vide = même origine (le serveur Hono sert front + API).
    const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? '').replace(/\/$/, '')

    const messages: Record<string, string> = {
      invalid_email: 'Adresse e-mail invalide.',
      consent_required: 'Merci de cocher la case de consentement.',
      server_misconfigured:
        'Service momentanément indisponible. Réessaie plus tard.',
      brevo_error: "L'inscription a échoué. Réessaie dans un instant.",
      network_error: 'Problème de connexion. Vérifie ton réseau et réessaie.',
      default: 'Une erreur est survenue. Réessaie.',
    }

    function showError(msg: string) {
      errorEl.hidden = false
      errorEl.textContent = msg
    }

    function showSuccess() {
      form.hidden = true
      successEl.hidden = false
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const data = new FormData(form)
      const payload = {
        firstname: String(data.get('firstname') ?? ''),
        email: String(data.get('email') ?? ''),
        country: String(data.get('country') ?? ''),
        consent: data.get('consent') === 'on',
        website: String(data.get('website') ?? ''),
      }

      button.disabled = true
      errorEl.hidden = true

      try {
        const res = await fetch(`${API_BASE}/api/subscribe`, {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload),
        })
        const json = await res.json().catch(() => ({}))

        if (res.ok && json.ok) {
          showSuccess()
        } else {
          showError(messages[json.error] ?? messages.default)
        }
      } catch {
        showError(messages.network_error)
      } finally {
        button.disabled = false
      }
    })
  </script>

  <script>
    type Session = { date: string; start: string; end: string | null }

    type EventRecord = {
      id: string
      title: string
      slug: string
      start: string
      location?: string
      description?: string
      poster?: string
      category?: string
      sessions?: Session[]
    }

    const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? '').replace(/\/$/, '')

    function stripHtml(s: string): string {
      return s
        .replace(/<[^>]*>/g, ' ')
        .replace(/&nbsp;/g, ' ')
        .replace(/&amp;/g, '&')
        .replace(/\s+/g, ' ')
        .trim()
    }

    const CATEGORIES: Record<string, string> = {
      stage: 'Stage',
      concert: 'Concert',
      festival: 'Festival',
      rencontre: 'Rencontre',
      autre: 'Autre',
    }

    const loadingEl = document.getElementById('ev-loading') as HTMLDivElement
    const emptyEl = document.getElementById('ev-empty') as HTMLDivElement
    const errorEl = document.getElementById('ev-error') as HTMLDivElement
    const gridEl = document.getElementById('ev-grid') as HTMLDivElement
    const ctaEl = document.getElementById('ev-cta') as HTMLDivElement

    const dayFmt = new Intl.DateTimeFormat('fr-BE', {
      weekday: 'short',
      day: 'numeric',
      month: 'short',
    })
    const timeFmt = new Intl.DateTimeFormat('fr-BE', {
      hour: '2-digit',
      minute: '2-digit',
    })

    function nowUtcFilter(): string {
      return new Date().toISOString().slice(0, 19).replace('T', ' ')
    }

    function parseDate(raw: string): Date {
      return new Date(raw.replace(' ', 'T'))
    }

    function posterUrl(ev: EventRecord): string | null {
      if (!ev.poster) return null
      return `${API_BASE}/pb/api/files/events/${ev.id}/${ev.poster}`
    }

    function capitalize(s: string): string {
      return s.charAt(0).toUpperCase() + s.slice(1)
    }

    function eventCard(ev: EventRecord): HTMLAnchorElement {
      const a = document.createElement('a')
      a.href = `/evenements/${ev.slug}`
      a.className =
        'group flex gap-4 rounded-2xl bg-white p-3.5 ring-1 ring-stone-900/5 shadow-card transition hover:shadow-card-hover hover:ring-brand-200'

      const thumb = document.createElement('div')
      thumb.className =
        'relative h-24 w-24 shrink-0 overflow-hidden rounded-xl bg-brand-100 ring-1 ring-inset ring-stone-900/5 sm:h-28 sm:w-28'
      const img = document.createElement('img')
      const src = posterUrl(ev)
      img.src = src ?? '/didge-placeholder.webp'
      img.alt = src ? `Affiche : ${ev.title}` : ''
      img.loading = 'lazy'
      img.className = 'h-full w-full object-cover'
      thumb.appendChild(img)

      const body = document.createElement('div')
      body.className = 'flex min-w-0 flex-col justify-center gap-1 py-1'

      const start = parseDate(ev.start)
      const dateLine = document.createElement('p')
      dateLine.className =
        'text-[11px] font-semibold uppercase tracking-[0.12em] text-brand-600'
      dateLine.textContent = `${capitalize(dayFmt.format(start))} · ${timeFmt.format(start)}`

      body.appendChild(dateLine)

      const extra =
        Array.isArray(ev.sessions) && ev.sessions.length > 1
          ? ev.sessions.length - 1
          : 0
      if (extra > 0) {
        const more = document.createElement('p')
        more.className = 'text-[12px] text-stone-400'
        more.textContent = `+${extra} autre${extra > 1 ? 's' : ''} date${extra > 1 ? 's' : ''}`
        body.appendChild(more)
      }

      const title = document.createElement('h3')
      title.className =
        'truncate text-[16px] font-bold leading-snug tracking-tight text-stone-900'
      title.textContent = ev.title

      body.appendChild(title)

      const excerpt = ev.description ? stripHtml(ev.description) : ''
      if (excerpt) {
        const desc = document.createElement('p')
        desc.className =
          'line-clamp-2 text-[12.5px] leading-relaxed text-stone-500'
        desc.textContent = excerpt
        body.appendChild(desc)
      }

      if (ev.category && CATEGORIES[ev.category]) {
        const badge = document.createElement('span')
        badge.className =
          'mt-0.5 inline-flex w-fit rounded-full bg-stone-100 px-2.5 py-0.5 text-[10.5px] font-semibold uppercase tracking-[0.1em] text-stone-500'
        badge.textContent = CATEGORIES[ev.category]
        body.appendChild(badge)
      }

      if (ev.location) {
        const loc = document.createElement('p')
        loc.className = 'truncate text-[13px] text-stone-500'
        loc.textContent = ev.location
        body.appendChild(loc)
      }

      a.append(thumb, body)
      return a
    }

    async function load() {
      const filter = encodeURIComponent(
        `(status='published' && start >= '${nowUtcFilter()}')`,
      )
      const url = `${API_BASE}/pb/api/collections/events/records?filter=${filter}&sort=start&perPage=6`
      try {
        const res = await fetch(url)
        if (!res.ok) throw new Error(`HTTP ${res.status}`)
        const json = await res.json()
        const events = (json.items ?? []) as EventRecord[]
        loadingEl.hidden = true

        if (events.length === 0) {
          emptyEl.hidden = false
          return
        }

        for (const ev of events) gridEl.appendChild(eventCard(ev))
        gridEl.hidden = false
        ctaEl.hidden = false
      } catch {
        loadingEl.hidden = true
        errorEl.hidden = false
      }
    }

    load()
  </script>
</Layout>
