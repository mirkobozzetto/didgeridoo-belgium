---
import Layout from '../layouts/Layout.astro'
import AccountNav from '../components/AccountNav.astro'
---

<Layout title="Mes propositions — Didgeridoo Belgique">
  <div
    class="mx-auto flex min-h-[100dvh] max-w-2xl flex-col px-5 py-10 sm:px-8"
  >
    <AccountNav active="mes-propositions" />

    <section class="flex flex-wrap items-end justify-between gap-4 py-7">
      <div>
        <p
          class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
        >
          Espace organisateur
        </p>
        <h1
          class="balance mt-1.5 text-[clamp(1.8rem,4vw,2.4rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-stone-900"
        >
          Mes propositions
        </h1>
      </div>
      <a
        href="/proposer"
        class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 px-4 py-2.5 text-[14px] font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px"
      >
        Proposer un événement
      </a>
    </section>

    <div id="state" class="py-10 text-center text-[14px] text-stone-400">
      Chargement…
    </div>
    <div
      id="empty"
      hidden
      class="rounded-2xl border border-dashed border-stone-300 bg-white/60 px-6 py-12 text-center"
    >
      <p class="text-[15px] font-semibold text-stone-700">
        Aucune proposition pour l'instant
      </p>
      <p class="pretty mx-auto mt-1.5 max-w-sm text-[13px] text-stone-500">
        Propose ton premier événement, il passera en relecture avant
        publication.
      </p>
    </div>
    <ul id="list" class="flex flex-col gap-4"></ul>
  </div>

  <template id="card-tpl">
    <li
      class="relative overflow-hidden rounded-2xl bg-white p-5 shadow-[0_2px_4px_rgb(0_0_0/0.04),0_16px_40px_-24px_rgb(28_25_23/0.35)] ring-1 ring-stone-900/5"
    >
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <h2
            data-title
            class="balance text-[16px] font-bold leading-snug tracking-tight text-stone-900"
          >
          </h2>
          <p data-meta class="mt-1 text-[12.5px] text-stone-500"></p>
        </div>
        <span
          data-badge
          class="shrink-0 rounded-full px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.12em]"
        ></span>
      </div>
      <div
        data-reason
        hidden
        class="mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-[13px] leading-relaxed text-red-700"
      >
      </div>
      <div data-actions hidden class="mt-4">
        <a
          data-edit
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-stone-900 px-4 py-2 text-[13px] font-semibold text-white transition hover:bg-stone-700 active:translate-y-px"
        >
          Corriger et renvoyer
        </a>
      </div>
    </li>
  </template>

  <script>
    import { pb, getAuth, clearAuth, fromPbDate } from '../lib/pb'

    const auth = getAuth()
    if (!auth) location.replace('/connexion')

    const stateEl = document.getElementById('state') as HTMLDivElement
    const emptyEl = document.getElementById('empty') as HTMLDivElement
    const listEl = document.getElementById('list') as HTMLUListElement
    const tpl = document.getElementById('card-tpl') as HTMLTemplateElement

    const STATUS: Record<string, { label: string; cls: string }> = {
      pending: {
        label: 'En attente',
        cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200',
      },
      published: {
        label: 'Publiée',
        cls: 'bg-brand-100 text-brand-700 ring-1 ring-inset ring-brand-200',
      },
      rejected: {
        label: 'Refusée',
        cls: 'bg-red-50 text-red-700 ring-1 ring-inset ring-red-200',
      },
    }

    interface EventRecord {
      id: string
      title: string
      start: string
      end: string
      location: string
      status: string
      rejection_reason: string
    }

    function render(items: EventRecord[]) {
      stateEl.hidden = true
      if (!items.length) {
        emptyEl.hidden = false
        return
      }
      for (const ev of items) {
        const node = tpl.content.firstElementChild!.cloneNode(
          true,
        ) as HTMLElement
        const meta = STATUS[ev.status] ?? {
          label: ev.status,
          cls: 'bg-stone-100 text-stone-600',
        }

        ;(node.querySelector('[data-title]') as HTMLElement).textContent =
          ev.title
        ;(node.querySelector('[data-meta]') as HTMLElement).textContent = [
          fromPbDate(ev.start),
          ev.location,
        ]
          .filter(Boolean)
          .join(' · ')

        const badge = node.querySelector('[data-badge]') as HTMLElement
        badge.textContent = meta.label
        badge.className = `shrink-0 rounded-full px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.12em] ${meta.cls}`

        if (ev.status === 'rejected') {
          const reason = node.querySelector('[data-reason]') as HTMLElement
          reason.hidden = false
          reason.textContent = ev.rejection_reason
            ? `Motif du refus : ${ev.rejection_reason}`
            : 'Fiche refusée. Corrige-la puis renvoie-la en relecture.'
        }

        if (ev.status === 'rejected' || ev.status === 'pending') {
          const actions = node.querySelector('[data-actions]') as HTMLElement
          actions.hidden = false
          const edit = node.querySelector('[data-edit]') as HTMLAnchorElement
          edit.href = `/proposer?id=${ev.id}`
          edit.textContent =
            ev.status === 'rejected' ? 'Corriger et renvoyer' : 'Modifier'
        }

        listEl.appendChild(node)
      }
    }

    async function load() {
      try {
        const filter = encodeURIComponent(`organizer='${auth!.record.id}'`)
        const res = await pb<{ items: EventRecord[] }>(
          `/api/collections/events/records?perPage=100&filter=(${filter})&sort=-created`,
          { auth: true },
        )
        render(res.items)
      } catch (err) {
        const status = (err as { status?: number })?.status
        if (status === 401) {
          clearAuth()
          location.replace('/connexion')
          return
        }
        stateEl.textContent =
          'Impossible de charger tes propositions. Réessaie.'
      }
    }

    load()
  </script>
</Layout>
