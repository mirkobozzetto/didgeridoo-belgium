---
import Layout from '../layouts/Layout.astro'
import PageShell from '../layouts/PageShell.astro'
import { btn } from '../lib/button-styles'
---

<Layout title="Mes propositions — Didgeridoo Belgique">
  <PageShell width="2xl" nav active="mes-propositions">
    <section class="flex flex-wrap items-end justify-between gap-4 py-7">
      <div>
        <p
          class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
        >
          Espace organisateur
        </p>
        <h1
          class="balance mt-1.5 text-[clamp(1.8rem,4vw,2.4rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-stone-900"
        >
          Mes propositions
        </h1>
      </div>
      <a href="/proposer" class={btn('outline', 'sm')}> + Nouvel événement </a>
    </section>

    <div id="state" class="py-8 text-center text-[14px] text-stone-400">
      Chargement…
    </div>
    <div
      id="empty"
      hidden
      class="rounded-2xl border border-dashed border-stone-300 bg-white/60 px-6 py-10 text-center"
    >
      <p class="text-[15px] font-semibold text-stone-700">
        Aucune proposition pour l'instant
      </p>
      <p class="pretty mx-auto mt-1.5 max-w-sm text-[13px] text-stone-500">
        Propose ton premier événement, il passera en relecture avant
        publication.
      </p>
    </div>
    <ul id="list" class="mt-4 flex flex-col gap-4"></ul>

    <section
      class="mt-10 flex flex-wrap items-end justify-between gap-4 border-t border-stone-900/[0.07] pt-8"
    >
      <div>
        <p
          class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
        >
          Annonces
        </p>
        <h2
          class="balance mt-1.5 text-[clamp(1.4rem,3vw,1.8rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-stone-900"
        >
          Mes annonces
        </h2>
      </div>
      <a href="/proposer-annonce" class={btn('outline', 'sm')}>
        + Nouvelle annonce
      </a>
    </section>

    <div id="ann-state" class="py-8 text-center text-[14px] text-stone-400">
      Chargement…
    </div>
    <div
      id="ann-empty"
      hidden
      class="rounded-2xl border border-dashed border-stone-300 bg-white/60 px-6 py-10 text-center"
    >
      <p class="text-[15px] font-semibold text-stone-700">
        Aucune annonce pour l'instant
      </p>
      <p class="pretty mx-auto mt-1.5 max-w-sm text-[13px] text-stone-500">
        Vente d'instrument, cours, artisanat ou covoiturage : propose ta
        première annonce.
      </p>
    </div>
    <ul id="ann-list" class="mt-4 flex flex-col gap-4"></ul>
  </PageShell>

  <template id="card-tpl">
    <li
      class="relative overflow-hidden rounded-2xl bg-white p-5 shadow-card ring-1 ring-stone-900/5"
    >
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <h2
            data-title
            class="balance text-[16px] font-bold leading-snug tracking-tight text-stone-900"
          >
          </h2>
          <p data-meta class="mt-1 text-[12.5px] text-stone-500"></p>
        </div>
        <span
          data-badge
          class="shrink-0 rounded-full px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.12em]"
        ></span>
      </div>
      <div
        data-reason
        hidden
        class="mt-3 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-[13px] leading-relaxed text-red-700"
      >
      </div>
      <div data-actions hidden class="mt-4">
        <a data-edit class={btn('dark', 'xs')}> Corriger et renvoyer </a>
      </div>
    </li>
  </template>

  <script>
    import { pb, getAuth, clearAuth, fromPbDate } from '../lib/pb'
    import { btn } from '../lib/button-styles'
    import {
      annonceCategoryLabel,
      annonceIsExpired,
      type AnnonceRecord,
    } from '../lib/annonces'

    const auth = getAuth()
    if (!auth) location.replace('/connexion')

    const stateEl = document.getElementById('state') as HTMLDivElement
    const emptyEl = document.getElementById('empty') as HTMLDivElement
    const listEl = document.getElementById('list') as HTMLUListElement
    const tpl = document.getElementById('card-tpl') as HTMLTemplateElement

    const STATUS: Record<string, { label: string; cls: string }> = {
      pending: {
        label: 'En attente',
        cls: 'bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200',
      },
      published: {
        label: 'Publiée',
        cls: 'bg-brand-100 text-brand-700 ring-1 ring-inset ring-brand-200',
      },
      rejected: {
        label: 'Refusée',
        cls: 'bg-red-50 text-red-700 ring-1 ring-inset ring-red-200',
      },
    }

    interface EventRecord {
      id: string
      title: string
      start: string
      end: string
      location: string
      status: string
      rejection_reason: string
    }

    function render(items: EventRecord[]) {
      stateEl.hidden = true
      if (!items.length) {
        emptyEl.hidden = false
        return
      }
      for (const ev of items) {
        const node = tpl.content.firstElementChild!.cloneNode(
          true,
        ) as HTMLElement
        const meta = STATUS[ev.status] ?? {
          label: ev.status,
          cls: 'bg-stone-100 text-stone-600',
        }

        ;(node.querySelector('[data-title]') as HTMLElement).textContent =
          ev.title
        ;(node.querySelector('[data-meta]') as HTMLElement).textContent = [
          fromPbDate(ev.start),
          ev.location,
        ]
          .filter(Boolean)
          .join(' · ')

        const badge = node.querySelector('[data-badge]') as HTMLElement
        badge.textContent = meta.label
        badge.className = `shrink-0 rounded-full px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.12em] ${meta.cls}`

        if (ev.status === 'rejected') {
          const reason = node.querySelector('[data-reason]') as HTMLElement
          reason.hidden = false
          reason.textContent = ev.rejection_reason
            ? `Motif du refus : ${ev.rejection_reason}`
            : 'Fiche refusée. Corrige-la puis renvoie-la en relecture.'
        }

        if (ev.status === 'rejected' || ev.status === 'pending') {
          const actions = node.querySelector('[data-actions]') as HTMLElement
          actions.hidden = false
          const edit = node.querySelector('[data-edit]') as HTMLAnchorElement
          edit.href = `/proposer?id=${ev.id}`
          edit.textContent =
            ev.status === 'rejected' ? 'Corriger et renvoyer' : 'Modifier'
        }

        listEl.appendChild(node)
      }
    }

    async function load() {
      try {
        const filter = encodeURIComponent(`organizer='${auth!.record.id}'`)
        const res = await pb<{ items: EventRecord[] }>(
          `/api/collections/events/records?perPage=100&filter=(${filter})&sort=-created`,
          { auth: true },
        )
        render(res.items)
      } catch (err) {
        const status = (err as { status?: number })?.status
        if (status === 401) {
          clearAuth()
          location.replace('/connexion')
          return
        }
        stateEl.textContent =
          'Impossible de charger tes propositions. Réessaie.'
      }
    }

    const annState = document.getElementById('ann-state') as HTMLDivElement
    const annEmpty = document.getElementById('ann-empty') as HTMLDivElement
    const annList = document.getElementById('ann-list') as HTMLUListElement

    function renderAnnonces(items: AnnonceRecord[]) {
      annState.hidden = true
      if (!items.length) {
        annEmpty.hidden = false
        return
      }
      for (const ann of items) {
        const expired = ann.status === 'published' && annonceIsExpired(ann)
        const node = tpl.content.firstElementChild!.cloneNode(
          true,
        ) as HTMLElement
        const meta = expired
          ? {
              label: 'Expirée',
              cls: 'bg-stone-100 text-stone-500 ring-1 ring-inset ring-stone-200',
            }
          : (STATUS[ann.status ?? ''] ?? {
              label: ann.status ?? '',
              cls: 'bg-stone-100 text-stone-600',
            })

        ;(node.querySelector('[data-title]') as HTMLElement).textContent =
          ann.title
        const metaParts = [annonceCategoryLabel(ann.category)]
        const expiresAt = ann.expires_at
        if (ann.status === 'published' && expiresAt && !expired) {
          metaParts.push(`En ligne jusqu'au ${fromPbDate(expiresAt)}`)
        }
        ;(node.querySelector('[data-meta]') as HTMLElement).textContent =
          metaParts.join(' · ')

        const badge = node.querySelector('[data-badge]') as HTMLElement
        badge.textContent = meta.label
        badge.className = `shrink-0 rounded-full px-3 py-1 text-[10.5px] font-semibold uppercase tracking-[0.12em] ${meta.cls}`

        if (ann.status === 'rejected') {
          const reason = node.querySelector('[data-reason]') as HTMLElement
          reason.hidden = false
          reason.textContent = ann.rejection_reason
            ? `Motif du refus : ${ann.rejection_reason}`
            : 'Annonce refusée. Corrige-la puis renvoie-la en relecture.'
        }

        const actions = node.querySelector('[data-actions]') as HTMLElement
        const edit = node.querySelector('[data-edit]') as HTMLAnchorElement

        if (ann.status === 'rejected' || ann.status === 'pending') {
          actions.hidden = false
          edit.href = `/proposer-annonce?id=${ann.id}`
          edit.textContent =
            ann.status === 'rejected' ? 'Corriger et renvoyer' : 'Modifier'
        }

        if (ann.status === 'published') {
          actions.hidden = false
          edit.remove()
          const renew = document.createElement('button')
          renew.type = 'button'
          renew.className = btn('dark', 'xs')
          renew.textContent = expired
            ? 'Renouveler pour 45 jours'
            : 'Prolonger de 45 jours'
          renew.addEventListener('click', async () => {
            renew.disabled = true
            try {
              await pb(`/api/annonces/${ann.id}/renouveler`, {
                method: 'POST',
                auth: true,
              })
              location.reload()
            } catch {
              renew.disabled = false
              renew.textContent = 'Échec, réessaie'
            }
          })
          actions.appendChild(renew)
        }

        annList.appendChild(node)
      }
    }

    async function loadAnnonces() {
      try {
        const filter = encodeURIComponent(`author='${auth!.record.id}'`)
        const res = await pb<{ items: AnnonceRecord[] }>(
          `/api/collections/annonces/records?perPage=100&filter=(${filter})&sort=-created`,
          { auth: true },
        )
        renderAnnonces(res.items)
      } catch {
        annState.textContent = 'Impossible de charger tes annonces. Réessaie.'
      }
    }

    load()
    loadAnnonces()
  </script>
</Layout>
