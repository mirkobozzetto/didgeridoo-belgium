---
import Layout from '../layouts/Layout.astro'
import AccountNav from '../components/AccountNav.astro'
---

<Layout title="Proposer un événement — Didgeridoo Belgique">
  <div
    class="mx-auto flex min-h-[100dvh] max-w-2xl flex-col px-5 py-10 sm:px-8"
  >
    <AccountNav active="proposer" />

    <section class="py-7">
      <p
        class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
      >
        Proposer
      </p>
      <h1
        id="heading"
        class="balance mt-1.5 text-[clamp(1.8rem,4vw,2.4rem)] font-extrabold leading-[1.1] tracking-[-0.03em] text-stone-900"
      >
        Un événement à partager
      </h1>
      <p
        class="pretty mt-2 max-w-prose text-[14px] leading-[1.7] text-stone-600"
      >
        Remplis la fiche. Elle passe en relecture avant d'être publiée sur le
        site.
      </p>
    </section>

    <div
      class="relative overflow-hidden rounded-2xl bg-white p-6 shadow-[0_2px_4px_rgb(0_0_0/0.04),0_24px_60px_-24px_rgb(28_25_23/0.4)] ring-1 ring-stone-900/5 sm:p-8"
    >
      <span
        class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
      ></span>

      <form id="event-form" novalidate class="flex flex-col gap-5">
        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Titre <span class="text-brand-500">*</span></span
          >
          <input
            type="text"
            name="title"
            required
            placeholder="Stage de didgeridoo à Bruxelles"
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Catégorie <span class="text-brand-500">*</span></span
          >
          <select
            name="category"
            required
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 focus:outline-none"
          >
            <option value="" disabled selected>Choisis une catégorie</option>
            <option value="stage">Stage</option>
            <option value="concert">Concert</option>
            <option value="festival">Festival</option>
            <option value="rencontre">Rencontre</option>
            <option value="autre">Autre</option>
          </select>
        </label>

        <div class="block pb-1">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Dates <span class="text-brand-500">*</span></span
          >
          <div id="sessions" class="mt-2 flex flex-col gap-2.5"></div>
          <button
            type="button"
            id="add-session"
            class="mt-2.5 inline-flex items-center gap-1 text-[13px] font-semibold text-brand-600 transition-colors hover:text-brand-700"
            >+ Ajouter une date</button
          >
        </div>

        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Lieu <span class="text-brand-500">*</span></span
          >
          <input
            type="text"
            name="location"
            required
            placeholder="Adresse ou salle"
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <div class="block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Description <span class="text-brand-500">*</span></span
          >
          <div
            class="mt-1.5 overflow-hidden rounded-xl border border-stone-200 transition-colors focus-within:border-brand-600"
          >
            <div
              role="toolbar"
              aria-label="Mise en forme"
              class="flex flex-wrap items-center gap-0.5 border-b border-stone-200 bg-stone-50 px-2 py-1.5"
            >
              <button type="button" data-cmd="bold" class="rte-btn font-bold"
                >Gras</button
              >
              <button type="button" data-cmd="italic" class="rte-btn italic"
                >Italique</button
              >
              <button
                type="button"
                data-cmd="insertUnorderedList"
                class="rte-btn">Liste</button
              >
              <button type="button" data-link class="rte-btn">Lien</button>
              <button type="button" data-cmd="removeFormat" class="rte-btn"
                >Effacer le format</button
              >
            </div>
            <div
              id="link-row"
              hidden
              class="flex items-center gap-2 border-b border-stone-200 bg-white px-2.5 py-2"
            >
              <input
                id="link-url"
                type="url"
                placeholder="https://..."
                class="min-w-0 flex-1 bg-transparent text-[13px] text-stone-900 placeholder-stone-300 focus:outline-none"
              />
              <button
                type="button"
                id="link-apply"
                class="shrink-0 rounded-lg bg-brand-100 px-3 py-1 text-[12px] font-semibold text-brand-700 transition hover:bg-brand-200"
                >Ajouter</button
              >
              <button
                type="button"
                id="link-cancel"
                class="shrink-0 rounded-lg px-2 py-1 text-[12px] font-medium text-stone-400 transition hover:text-stone-600"
                >Annuler</button
              >
            </div>
            <div
              id="description-editor"
              contenteditable="true"
              role="textbox"
              aria-multiline="true"
              data-placeholder="Programme, ambiance, public visé, ce qu'il faut apporter..."
              class="rte-editor min-h-32 w-full bg-white px-3.5 py-3 text-[15px] leading-relaxed text-stone-900 focus:outline-none"
            >
            </div>
          </div>
        </div>

        <label class="block">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Affiche <span class="normal-case tracking-normal text-stone-300"
              >(jpeg, png ou webp, 5 Mo max)</span
            ></span
          >
          <input
            type="file"
            name="poster"
            accept="image/jpeg,image/png,image/webp"
            class="mt-2 block w-full text-[13px] text-stone-600 file:mr-4 file:rounded-lg file:border-0 file:bg-brand-100 file:px-4 file:py-2 file:text-[13px] file:font-semibold file:text-brand-700 hover:file:bg-brand-200"
          />
          <span
            id="current-poster"
            hidden
            class="mt-1.5 block text-[12px] text-stone-400"></span>
        </label>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="field block pb-2">
            <span
              class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
              >Prix <span class="normal-case tracking-normal text-stone-300"
                >(facultatif)</span
              ></span
            >
            <input
              type="text"
              name="price"
              placeholder="Gratuit, 15 €, prix libre..."
              class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
            />
          </label>
          <label class="field block pb-2">
            <span
              class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
              >Contact <span class="normal-case tracking-normal text-stone-300"
                >(facultatif)</span
              ></span
            >
            <input
              type="text"
              name="contact"
              placeholder="E-mail ou téléphone"
              class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
            />
          </label>
        </div>

        <label class="field block pb-2">
          <span
            class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
            >Lien d'inscription <span
              class="normal-case tracking-normal text-stone-300"
              >(facultatif)</span
            ></span
          >
          <input
            type="url"
            name="registration_url"
            placeholder="https://..."
            class="mt-1.5 w-full bg-transparent text-[15px] text-stone-900 placeholder-stone-300 focus:outline-none"
          />
        </label>

        <div class="hp" aria-hidden="true">
          <label
            >Site web<input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
            /></label
          >
        </div>

        <div
          id="error"
          hidden
          class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-[13px] text-red-700"
        >
        </div>

        <button
          type="submit"
          class="group/btn mt-1 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-b from-brand-500 to-brand-600 px-5 py-3.5 text-[15px] font-semibold text-white shadow-[inset_0_1px_0_rgb(255_255_255/0.25),0_1px_2px_rgb(0_0_0/0.1)] transition hover:from-brand-600 hover:to-brand-700 active:translate-y-px disabled:opacity-60"
        >
          <span id="submit-label">Envoyer en relecture</span>
        </button>
      </form>
    </div>

    <template id="session-template">
      <div
        data-session
        class="rounded-xl bg-stone-50 p-3.5 ring-1 ring-stone-900/5"
      >
        <div class="flex items-center gap-2">
          <button
            type="button"
            data-date-btn
            data-date=""
            class="flex-1 rounded-lg bg-white px-3 py-2 text-left text-[14px] text-stone-400 ring-1 ring-stone-900/10 transition-colors hover:ring-brand-400 focus:outline-none focus:ring-brand-500"
            >Choisir une date</button
          >
          <button
            type="button"
            data-remove
            aria-label="Retirer cette date"
            class="shrink-0 rounded-lg p-2 text-stone-400 transition-colors hover:bg-stone-200 hover:text-stone-700"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              aria-hidden="true"
            >
              <path d="M6 6l8 8M14 6l-8 8" stroke-linecap="round"></path>
            </svg>
          </button>
        </div>
        <div class="mt-2.5 grid grid-cols-2 gap-3">
          <label class="field block pb-1.5">
            <span
              class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
              >Début <span class="text-brand-500">*</span></span
            >
            <select
              data-start
              class="mt-1 w-full bg-transparent text-[14px] text-stone-900 focus:outline-none"
            ></select>
          </label>
          <label class="field block pb-1.5">
            <span
              class="block text-[10.5px] font-semibold uppercase tracking-[0.16em] text-stone-400"
              >Fin <span class="normal-case tracking-normal text-stone-300"
                >(optionnel)</span
              ></span
            >
            <select
              data-end
              class="mt-1 w-full bg-transparent text-[14px] text-stone-900 focus:outline-none"
            ></select>
          </label>
        </div>
      </div>
    </template>

    <div
      id="date-popover"
      hidden
      class="fixed z-30 w-[300px] max-w-[calc(100vw-16px)] rounded-xl bg-white p-2 shadow-[0_2px_4px_rgb(0_0_0/0.04),0_24px_60px_-24px_rgb(28_25_23/0.4)] ring-1 ring-stone-900/5"
    >
      <calendar-date id="date-calendar" locale="fr-BE" first-day-of-week="1">
        <svg
          aria-label="Mois précédent"
          slot="previous"
          class="h-4 w-4 text-stone-500"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        >
          <path d="M15.75 19.5 8.25 12l7.5-7.5" stroke-linecap="round"></path>
        </svg>
        <svg
          aria-label="Mois suivant"
          slot="next"
          class="h-4 w-4 text-stone-500"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
        >
          <path d="m8.25 4.5 7.5 7.5-7.5 7.5" stroke-linecap="round"></path>
        </svg>
        <calendar-select-month slot="heading"></calendar-select-month>
        <calendar-select-year slot="heading" max-years="6"
        ></calendar-select-year>
        <calendar-month></calendar-month>
      </calendar-date>
    </div>
  </div>

  <script>
    import 'cally'
    import { pb, getAuth, slugify, toPbDate } from '../lib/pb'

    const auth = getAuth()
    if (!auth) location.replace('/connexion')

    const MAX_BYTES = 5 * 1024 * 1024
    const ALLOWED = ['image/jpeg', 'image/png', 'image/webp']

    const params = new URLSearchParams(location.search)
    const editId = params.get('id')

    const form = document.getElementById('event-form') as HTMLFormElement
    const errorEl = document.getElementById('error') as HTMLDivElement
    const heading = document.getElementById('heading') as HTMLHeadingElement
    const submitLabel = document.getElementById(
      'submit-label',
    ) as HTMLSpanElement
    const currentPoster = document.getElementById(
      'current-poster',
    ) as HTMLSpanElement
    const button = form.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement
    const editor = document.getElementById(
      'description-editor',
    ) as HTMLDivElement
    const linkRow = document.getElementById('link-row') as HTMLDivElement
    const linkUrl = document.getElementById('link-url') as HTMLInputElement

    const ALLOWED_TAGS = new Set([
      'P',
      'BR',
      'B',
      'STRONG',
      'I',
      'EM',
      'UL',
      'OL',
      'LI',
      'A',
    ])

    function sanitize(html: string): string {
      const doc = new DOMParser().parseFromString(html, 'text/html')
      const walk = (node: Element) => {
        for (const el of Array.from(node.children)) {
          walk(el)
          if (!ALLOWED_TAGS.has(el.tagName)) {
            el.replaceWith(...Array.from(el.childNodes))
            continue
          }
          const href = el.tagName === 'A' ? (el.getAttribute('href') ?? '') : ''
          for (const attr of Array.from(el.attributes))
            el.removeAttribute(attr.name)
          if (el.tagName === 'A' && /^https?:\/\//i.test(href)) {
            el.setAttribute('href', href)
            el.setAttribute('rel', 'noopener')
            el.setAttribute('target', '_blank')
          }
        }
      }
      walk(doc.body)
      return doc.body.innerHTML
    }

    let savedRange: Range | null = null

    document.execCommand('defaultParagraphSeparator', false, 'p')

    function exec(cmd: string, value?: string) {
      // sans focus préalable, execCommand (Liste notamment) ne fait rien
      if (!editor.contains(document.getSelection()?.anchorNode ?? null)) {
        editor.focus()
      }
      document.execCommand(cmd, false, value)
      editor.focus()
    }

    for (const btn of Array.from(
      document.querySelectorAll<HTMLButtonElement>('.rte-btn'),
    )) {
      btn.addEventListener('mousedown', (e) => e.preventDefault())
    }

    for (const btn of Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-cmd]'),
    )) {
      btn.addEventListener('click', () => exec(btn.dataset.cmd as string))
    }

    const linkToggle = form.querySelector('[data-link]') as HTMLButtonElement
    const linkApply = document.getElementById('link-apply') as HTMLButtonElement
    const linkCancel = document.getElementById(
      'link-cancel',
    ) as HTMLButtonElement

    function closeLinkRow() {
      linkRow.hidden = true
      linkUrl.value = ''
      savedRange = null
    }

    linkToggle.addEventListener('click', () => {
      const sel = window.getSelection()
      savedRange = sel && sel.rangeCount ? sel.getRangeAt(0).cloneRange() : null
      linkRow.hidden = false
      linkUrl.focus()
    })

    linkApply.addEventListener('click', () => {
      const url = linkUrl.value.trim()
      if (!/^https?:\/\//i.test(url)) {
        linkUrl.focus()
        return
      }
      editor.focus()
      if (savedRange) {
        const sel = window.getSelection()
        sel?.removeAllRanges()
        sel?.addRange(savedRange)
      }
      if (savedRange && savedRange.collapsed) {
        const a = document.createElement('a')
        a.href = url
        a.textContent = url
        savedRange.insertNode(a)
        const sel = window.getSelection()
        const after = document.createRange()
        after.setStartAfter(a)
        after.collapse(true)
        sel?.removeAllRanges()
        sel?.addRange(after)
      } else {
        exec('createLink', url)
      }
      closeLinkRow()
    })

    linkCancel.addEventListener('click', closeLinkRow)

    interface Session {
      date: string
      start: string
      end: string | null
    }

    const sessionsList = document.getElementById('sessions') as HTMLDivElement
    const sessionTemplate = document.getElementById(
      'session-template',
    ) as HTMLTemplateElement
    const addSessionBtn = document.getElementById(
      'add-session',
    ) as HTMLButtonElement
    const popover = document.getElementById('date-popover') as HTMLDivElement
    const calendar = document.getElementById('date-calendar') as HTMLElement & {
      value: string
    }

    const dateFmt = new Intl.DateTimeFormat('fr-BE', {
      weekday: 'long',
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })

    function formatSessionDate(iso: string): string {
      if (!iso) return 'Choisir une date'
      const d = new Date(`${iso}T00:00:00`)
      if (Number.isNaN(d.getTime())) return 'Choisir une date'
      return dateFmt.format(d)
    }

    function setDate(dateBtn: HTMLButtonElement, iso: string) {
      dateBtn.dataset.date = iso
      dateBtn.textContent = formatSessionDate(iso)
      dateBtn.classList.toggle('text-stone-400', !iso)
      dateBtn.classList.toggle('text-stone-900', !!iso)
    }

    function updateRemoveVisibility() {
      const rows = sessionsList.querySelectorAll('[data-session]')
      for (const row of Array.from(rows)) {
        const btn = row.querySelector('[data-remove]') as HTMLElement
        btn.hidden = rows.length <= 1
      }
    }

    const QUARTER_SLOTS: string[] = []
    for (let h = 0; h < 24; h++) {
      for (const m of ['00', '15', '30', '45']) {
        QUARTER_SLOTS.push(`${String(h).padStart(2, '0')}:${m}`)
      }
    }

    function fillTimeOptions(select: HTMLSelectElement, optional: boolean) {
      const first = document.createElement('option')
      first.value = ''
      first.textContent = optional ? '-' : 'Début'
      if (!optional) {
        first.disabled = true
        first.selected = true
      }
      select.appendChild(first)
      for (const slot of QUARTER_SLOTS) {
        const opt = document.createElement('option')
        opt.value = slot
        opt.textContent = slot
        select.appendChild(opt)
      }
    }

    function setTimeValue(select: HTMLSelectElement, value: string) {
      if (!value) return
      // valeur héritée hors quart d'heure : on la garde telle quelle
      if (!QUARTER_SLOTS.includes(value)) {
        const opt = document.createElement('option')
        opt.value = value
        opt.textContent = value
        select.appendChild(opt)
      }
      select.value = value
    }

    function addSessionRow(session?: Session) {
      const frag = sessionTemplate.content.cloneNode(true) as DocumentFragment
      const row = frag.querySelector('[data-session]') as HTMLDivElement
      const dateBtn = row.querySelector('[data-date-btn]') as HTMLButtonElement
      const startEl = row.querySelector('[data-start]') as HTMLSelectElement
      const endEl = row.querySelector('[data-end]') as HTMLSelectElement
      const removeBtn = row.querySelector('[data-remove]') as HTMLButtonElement

      fillTimeOptions(startEl, false)
      fillTimeOptions(endEl, true)
      setDate(dateBtn, session?.date ?? '')
      setTimeValue(startEl, session?.start ?? '')
      setTimeValue(endEl, session?.end ?? '')

      dateBtn.addEventListener('click', () => openPopover(dateBtn))
      removeBtn.addEventListener('click', () => {
        row.remove()
        updateRemoveVisibility()
      })

      sessionsList.appendChild(row)
      updateRemoveVisibility()
    }

    addSessionBtn.addEventListener('click', () => addSessionRow())

    const today = new Date()
    const pad = (n: number) => String(n).padStart(2, '0')
    const todayIso = `${today.getFullYear()}-${pad(today.getMonth() + 1)}-${pad(
      today.getDate(),
    )}`
    calendar.setAttribute('min', todayIso)
    calendar.setAttribute('today', todayIso)

    let activeBtn: HTMLButtonElement | null = null

    function positionPopover(btn: HTMLButtonElement) {
      const r = btn.getBoundingClientRect()
      const maxLeft = window.innerWidth - popover.offsetWidth - 8
      const left = Math.max(8, Math.min(r.left, maxLeft))
      popover.style.left = `${left}px`
      popover.style.top = `${r.bottom + 6}px`
    }

    function openPopover(btn: HTMLButtonElement) {
      activeBtn = btn
      const current = btn.dataset.date ?? ''
      calendar.value = current
      if (current) calendar.setAttribute('focused-date', current)
      else calendar.removeAttribute('focused-date')
      popover.hidden = false
      positionPopover(btn)
    }

    function closePopover() {
      popover.hidden = true
      activeBtn = null
    }

    calendar.addEventListener('change', () => {
      if (!activeBtn) return
      setDate(activeBtn, calendar.value)
      closePopover()
    })

    document.addEventListener('click', (e) => {
      if (popover.hidden) return
      const t = e.target as Node
      if (popover.contains(t) || (activeBtn && activeBtn.contains(t))) return
      closePopover()
    })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !popover.hidden) closePopover()
    })
    window.addEventListener(
      'scroll',
      () => {
        if (!popover.hidden) closePopover()
      },
      true,
    )
    window.addEventListener('resize', () => {
      if (!popover.hidden) closePopover()
    })

    function showError(msg: string) {
      errorEl.hidden = false
      errorEl.textContent = msg
      errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' })
    }

    function toLocalInput(pbDate: string): string {
      if (!pbDate) return ''
      const d = new Date(
        pbDate.replace(' ', 'T') + (pbDate.includes('Z') ? '' : 'Z'),
      )
      if (Number.isNaN(d.getTime())) return ''
      const p = (n: number) => String(n).padStart(2, '0')
      return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}T${p(d.getHours())}:${p(d.getMinutes())}`
    }

    interface EventRecord {
      status: string
      title: string
      category: string
      start: string
      end: string
      location: string
      description: string
      price: string
      contact: string
      registration_url: string
      poster: string
      sessions?: Session[] | string
    }

    async function loadForEdit(id: string) {
      try {
        const rec = await pb<EventRecord>(
          `/api/collections/events/records/${id}`,
          { auth: true },
        )
        if (rec.status !== 'rejected' && rec.status !== 'pending') {
          location.replace('/mes-propositions')
          return
        }
        if (rec.status === 'rejected') {
          heading.textContent = 'Corriger la fiche'
          submitLabel.textContent = 'Renvoyer en relecture'
        } else {
          heading.textContent = 'Modifier la fiche'
          submitLabel.textContent = 'Enregistrer les modifications'
        }
        const set = (name: string, value: string) => {
          const el = form.elements.namedItem(name) as
            HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null
          if (el) el.value = value ?? ''
        }
        set('title', rec.title)
        set('category', rec.category)
        set('location', rec.location)

        let sessions: Session[] = []
        const raw = rec.sessions
        if (Array.isArray(raw)) {
          sessions = raw
        } else if (typeof raw === 'string' && raw) {
          try {
            sessions = JSON.parse(raw) as Session[]
          } catch {
            sessions = []
          }
        }
        if (sessions.length === 0 && rec.start) {
          const [sd, st] = toLocalInput(rec.start).split('T')
          const et = rec.end ? toLocalInput(rec.end).split('T')[1] : null
          sessions = [{ date: sd, start: st, end: et }]
        }
        for (const s of sessions) addSessionRow(s)
        if (sessionsList.children.length === 0) addSessionRow()

        editor.innerHTML = sanitize(rec.description ?? '')
        set('price', rec.price)
        set('contact', rec.contact)
        set('registration_url', rec.registration_url)
        if (rec.poster) {
          currentPoster.hidden = false
          currentPoster.textContent = `Affiche actuelle conservée si tu n'en choisis pas une nouvelle.`
        }
      } catch {
        location.replace('/mes-propositions')
      }
    }

    if (editId) loadForEdit(editId)
    else addSessionRow()

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const data = new FormData(form)
      if (String(data.get('website') ?? '')) return

      const title = String(data.get('title') ?? '').trim()
      const category = String(data.get('category') ?? '')
      const location = String(data.get('location') ?? '').trim()
      const description = editor.innerText.trim()
      const poster = data.get('poster') as File | null

      if (!title || !category || !location || !description) {
        showError('Titre, catégorie, lieu et description sont obligatoires.')
        return
      }

      const sessions: Session[] = []
      for (const row of Array.from(
        sessionsList.querySelectorAll('[data-session]'),
      )) {
        const date =
          (row.querySelector('[data-date-btn]') as HTMLElement).dataset.date ??
          ''
        const startTime = (
          row.querySelector('[data-start]') as HTMLSelectElement
        ).value
        const endTime = (row.querySelector('[data-end]') as HTMLSelectElement)
          .value
        if (!date || !startTime) {
          showError('Chaque date doit avoir un jour et une heure de début.')
          return
        }
        if (endTime && endTime <= startTime) {
          showError("L'heure de fin doit être après l'heure de début.")
          return
        }
        sessions.push({ date, start: startTime, end: endTime || null })
      }
      if (sessions.length === 0) {
        showError('Ajoute au moins une date.')
        return
      }
      sessions.sort((a, b) =>
        `${a.date}T${a.start}`.localeCompare(`${b.date}T${b.start}`),
      )
      if (poster && poster.size > 0) {
        if (!ALLOWED.includes(poster.type)) {
          showError("L'affiche doit être au format jpeg, png ou webp.")
          return
        }
        if (poster.size > MAX_BYTES) {
          showError("L'affiche dépasse 5 Mo.")
          return
        }
      }

      const payload = new FormData()
      payload.set('title', title)
      payload.set('category', category)
      const first = sessions[0]
      const last = sessions[sessions.length - 1]
      payload.set('start', toPbDate(`${first.date}T${first.start}`))
      payload.set('end', last.end ? toPbDate(`${last.date}T${last.end}`) : '')
      payload.set('sessions', JSON.stringify(sessions))
      payload.set('location', location)
      payload.set('description', sanitize(editor.innerHTML))
      payload.set('price', String(data.get('price') ?? '').trim())
      payload.set('contact', String(data.get('contact') ?? '').trim())
      payload.set(
        'registration_url',
        String(data.get('registration_url') ?? '').trim(),
      )
      payload.set('status', 'pending')
      if (poster && poster.size > 0) payload.set('poster', poster)

      button.disabled = true
      errorEl.hidden = true

      try {
        if (editId) {
          await pb(`/api/collections/events/records/${editId}`, {
            method: 'PATCH',
            body: payload,
            auth: true,
          })
        } else {
          payload.set('slug', slugify(title))
          payload.set('organizer', auth!.record.id)
          await pb('/api/collections/events/records', {
            method: 'POST',
            body: payload,
            auth: true,
          })
        }
        window.location.replace('/mes-propositions')
      } catch (err) {
        const status = (err as { status?: number })?.status
        if (status === 401 || status === 403) {
          showError('Session expirée. Reconnecte-toi.')
        } else {
          showError("L'envoi a échoué. Vérifie les champs et réessaie.")
        }
      } finally {
        button.disabled = false
      }
    })
  </script>

  <style>
    .hp {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .rte-btn {
