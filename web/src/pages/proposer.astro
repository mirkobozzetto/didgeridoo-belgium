      margin: 0 0 0.5rem;
    }
  </style>

  <style is:global>
    /* --color-accent hérite jusqu'au calendar-month, qui l'utilise dans son
       shadow DOM ; les ::part percent le shadow pour le reste. */
    #date-calendar {
      --color-accent: var(--color-brand-600);
      --color-text-on-accent: #ffffff;
      font-size: 14px;
      color: #1c1917;
    }
    #date-calendar::part(button) {
      border: none;
      background: transparent;
      padding: 0.375rem;
      border-radius: 0.5rem;
    }
    #date-calendar::part(button):hover {
      background-color: #f5f5f4;
    }
    #date-calendar::part(button):focus-visible {
      outline: 2px solid var(--color-brand-600);
      outline-offset: 1px;
    }
    /* le heading texte est remplacé par les selects mois + année */
    #date-calendar calendar-month::part(heading) {
      display: none;
    }
    #date-calendar calendar-select-month::part(select),
    #date-calendar calendar-select-year::part(select) {
      border: none;
      background: transparent;
      font-size: 14px;
      font-weight: 600;
      color: #1c1917;
      padding: 0.25rem 0.125rem;
      cursor: pointer;
    }
    #date-calendar calendar-select-month::part(select):focus-visible,
    #date-calendar calendar-select-year::part(select):focus-visible {
      outline: 2px solid var(--color-brand-600);
      outline-offset: 1px;
      border-radius: 0.375rem;
    }
  </style>
</Layout>
