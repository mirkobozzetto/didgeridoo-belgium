    }

    .rte-editor:empty::before {
      content: attr(data-placeholder);
      color: #d6d3d1;
      pointer-events: none;
    }
    .rte-editor ul {
      list-style: disc;
      padding-left: 1.25rem;
    }
    .rte-editor ol {
      list-style: decimal;
      padding-left: 1.25rem;
    }
    .rte-editor a {
      color: var(--color-brand-600);
      text-decoration: underline;
    }
