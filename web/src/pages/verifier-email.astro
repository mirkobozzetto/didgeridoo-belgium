---
import Layout from '../layouts/Layout.astro'
import PageShell from '../layouts/PageShell.astro'
import Brand from '../components/Brand.astro'
import { btn } from '../lib/button-styles'
---

<Layout title="Vérification de l'e-mail — Didgeridoo Belgique">
  <PageShell width="md" center>
    <header class="pb-6 text-center">
      <Brand />
    </header>

    <div
      class="relative overflow-hidden rounded-2xl bg-white p-6 text-center shadow-card ring-1 ring-stone-900/5"
    >
      <span
        class="pointer-events-none absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-brand-600 via-brand-400 to-transparent"
      ></span>

      <p
        class="text-[10.5px] font-semibold uppercase tracking-[0.22em] text-brand-600"
      >
        Espace organisateur
      </p>
      <h1
        id="heading"
        class="balance mt-1.5 text-[19px] font-bold leading-snug tracking-tight text-stone-900"
      >
        Vérification en cours…
      </h1>
      <p
        id="message"
        class="pretty mt-1.5 text-[13px] leading-relaxed text-stone-600"
      >
        Un instant.
      </p>

      <a
        id="cta"
        href="/connexion"
        hidden
        class:list={[btn('primary', 'lg'), 'mt-5 w-full']}>Me connecter</a
      >
    </div>

    <p class="mt-6 text-center text-[11.5px] text-stone-400">
      <a href="/" class="hover:text-stone-600">Retour à l'accueil</a>
    </p>
  </PageShell>

  <script>
    import { pb } from '../lib/pb'

    const heading = document.getElementById('heading') as HTMLHeadingElement
    const message = document.getElementById('message') as HTMLParagraphElement
    const cta = document.getElementById('cta') as HTMLAnchorElement

    const token = new URLSearchParams(location.search).get('token') ?? ''

    async function run() {
      if (!token) {
        heading.textContent = 'Lien invalide'
        message.textContent =
          'Ce lien de vérification est incomplet. Reprends le lien exact reçu par e-mail.'
        return
      }
      try {
        await pb('/api/collections/users/confirm-verification', {
          method: 'POST',
          body: { token },
        })
        heading.textContent = 'Compte activé'
        message.textContent =
          'Ton adresse est confirmée. Tu peux maintenant te connecter.'
        cta.hidden = false
      } catch {
        heading.textContent = 'Lien invalide ou expiré'
        message.textContent =
          'Ce lien ne fonctionne plus. Reconnecte-toi pour recevoir un nouvel e-mail, ou refais une demande.'
      }
    }

    run()
  </script>
</Layout>
